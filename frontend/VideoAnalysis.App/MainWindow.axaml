<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VideoAnalysis.App.ViewModels"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        x:Class="VideoAnalysis.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1600"
        Height="960"
        MinWidth="1280"
        MinHeight="760"
        Title="Video Analytics - Hockey MVP">

  <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="360,*,380" Margin="10">
    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Padding="10" CornerRadius="8" Background="#1E1E1E">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock VerticalAlignment="Center" Text="Hockey Video Analytics" FontSize="20" FontWeight="Bold"/>
        <TextBlock Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center" Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
        <Button Grid.Column="2" Command="{Binding SaveSettingsCommand}" Content="Save Cloud Settings" Padding="12,8"/>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" Grid.Column="0" Margin="0,10,10,10">
      <StackPanel Spacing="10">
        <Border Padding="8" Background="#F3F3F3" CornerRadius="6">
          <StackPanel Spacing="6">
            <TextBlock Text="1) Import Video" FontWeight="SemiBold"/>
            <TextBox Watermark="C:\match.mp4" Text="{Binding SourceVideoPath}"/>
            <Button Command="{Binding ImportFromPathCommand}" Content="Import"/>
          </StackPanel>
        </Border>

        <Border Padding="8" Background="#F3F3F3" CornerRadius="6">
          <StackPanel Spacing="6">
            <TextBlock Text="2) Tags" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding TagPresets}" SelectedItem="{Binding SelectedPreset}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Command="{Binding AddPresetCommand}" Content="Add Custom Preset"/>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
              <TextBox Grid.Column="0" Watermark="Start frame" Text="{Binding TagStartFrame}"/>
              <TextBox Grid.Column="1" Watermark="End frame" Text="{Binding TagEndFrame}"/>
            </Grid>
            <TextBox Watermark="Player" Text="{Binding TagPlayer}"/>
            <TextBox Watermark="Period" Text="{Binding TagPeriod}"/>
            <TextBox Watermark="Comment" Text="{Binding TagNotes}"/>
            <Button Command="{Binding AddTagCommand}" Content="Add Tag"/>
          </StackPanel>
        </Border>

        <Border Padding="8" Background="#F3F3F3" CornerRadius="6">
          <StackPanel Spacing="6">
            <TextBlock Text="3) Clips" FontWeight="SemiBold"/>
            <TextBox Watermark="Filter player" Text="{Binding FilterPlayer}"/>
            <TextBox Watermark="Filter period" Text="{Binding FilterPeriod}"/>
            <TextBox Watermark="Filter text" Text="{Binding FilterText}"/>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
              <TextBox Grid.Column="0" Watermark="Pre-roll frames" Text="{Binding PreRollFrames}"/>
              <TextBox Grid.Column="1" Watermark="Post-roll frames" Text="{Binding PostRollFrames}"/>
            </Grid>
            <Button Command="{Binding BuildClipsCommand}" Content="Build Segments"/>
            <TextBlock Text="{Binding ClipSummary}" FontWeight="SemiBold"/>
          </StackPanel>
        </Border>

        <Border Padding="8" Background="#F3F3F3" CornerRadius="6">
          <StackPanel Spacing="6">
            <TextBlock Text="4) Annotations" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding ShapeTypes}" SelectedItem="{Binding SelectedShapeType}"/>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
              <TextBox Grid.Column="0" Watermark="Start frame" Text="{Binding AnnotationStartFrame}"/>
              <TextBox Grid.Column="1" Watermark="End frame" Text="{Binding AnnotationEndFrame}"/>
            </Grid>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
              <TextBox Grid.Column="0" Watermark="X1" Text="{Binding AnnotationX1}"/>
              <TextBox Grid.Column="1" Watermark="Y1" Text="{Binding AnnotationY1}"/>
            </Grid>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
              <TextBox Grid.Column="0" Watermark="X2" Text="{Binding AnnotationX2}"/>
              <TextBox Grid.Column="1" Watermark="Y2" Text="{Binding AnnotationY2}"/>
            </Grid>
            <TextBox Watermark="Text" Text="{Binding AnnotationText}"/>
            <TextBox Watermark="#RRGGBB" Text="{Binding AnnotationColor}"/>
            <Button Command="{Binding AddAnnotationCommand}" Content="Add Annotation"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,10" RowDefinitions="*,Auto,Auto">
      <Border Grid.Row="0" Background="Black" CornerRadius="8">
        <vlc:VideoView x:Name="PlayerView" />
      </Border>

      <Slider Grid.Row="1"
              Margin="0,10,0,0"
              Minimum="0"
              Maximum="{Binding DurationFrames}"
              Value="{Binding CurrentFrame, Mode=TwoWay}"/>

      <Grid Grid.Row="2" Margin="0,10,0,0" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">
        <Button Grid.Column="0" Command="{Binding StepBackwardCommand}" Content="-1 frame" Padding="10,6"/>
        <Button Grid.Column="1" Margin="8,0,0,0" Command="{Binding TogglePlayPauseCommand}" Content="Play / Pause" Padding="10,6"/>
        <Button Grid.Column="2" Margin="8,0,0,0" Command="{Binding StepForwardCommand}" Content="+1 frame" Padding="10,6"/>
        <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="Frame:" FontWeight="SemiBold"/>
        <TextBlock Grid.Column="5" Margin="6,0,0,0" VerticalAlignment="Center" Text="{Binding CurrentFrame}"/>
      </Grid>
    </Grid>

    <Grid Grid.Row="1" Grid.Column="2" Margin="10,10,0,10" RowDefinitions="Auto,*,Auto,*">
      <TextBlock Grid.Row="0" Text="Tag Events" FontWeight="SemiBold" FontSize="15"/>
      <ListBox Grid.Row="1" ItemsSource="{Binding TagEvents}" SelectedItem="{Binding SelectedTagEvent}" Margin="0,6,0,6">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Padding="6" Margin="0,0,0,4" Background="#F6F6F6" CornerRadius="4">
              <StackPanel>
                <TextBlock Text="{Binding PresetName}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding StartFrame, StringFormat='Start: {0}'}"/>
                <TextBlock Text="{Binding EndFrame, StringFormat='End: {0}'}"/>
                <TextBlock Text="{Binding Player, StringFormat='Player: {0}'}"/>
                <TextBlock Text="{Binding Notes}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <Button Grid.Row="2" Command="{Binding DeleteSelectedTagCommand}" Content="Delete Selected Tag" HorizontalAlignment="Left"/>

      <StackPanel Grid.Row="3" Margin="0,12,0,0" Spacing="6">
        <TextBlock Text="Annotations" FontWeight="SemiBold" FontSize="15"/>
        <ListBox ItemsSource="{Binding Annotations}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Padding="6" Margin="0,0,0,4" Background="#F6F6F6" CornerRadius="4">
                <StackPanel>
                  <TextBlock Text="{Binding ShapeType}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding StartFrame, StringFormat='Start: {0}'}"/>
                  <TextBlock Text="{Binding EndFrame, StringFormat='End: {0}'}"/>
                  <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>
    </Grid>

    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Padding="10" CornerRadius="8" Background="#EFEFEF">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Output:" FontWeight="SemiBold"/>
        <TextBox Grid.Column="1" Text="{Binding ExportOutputPath}"/>
        <CheckBox Grid.Column="2" VerticalAlignment="Center" Content="Upload to Yandex" IsChecked="{Binding ExportToCloud}"/>
        <TextBox Grid.Column="3" Width="150" Watermark="Bucket" Text="{Binding YandexBucket}"/>
        <TextBox Grid.Column="4" Width="150" Watermark="Access key" Text="{Binding YandexAccessKey}"/>
        <TextBox Grid.Column="5" Width="150" Watermark="Secret key" Text="{Binding YandexSecretKey}"/>
        <Button Grid.Column="6" Command="{Binding ExportCommand}" Content="Export" Padding="16,8"/>
      </Grid>
    </Border>
  </Grid>
</Window>
