<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VideoAnalysis.App.ViewModels.Shell"
        xmlns:items="using:VideoAnalysis.App.ViewModels.Items"
        xmlns:converters="using:VideoAnalysis.App.Converters"
        xmlns:models="using:VideoAnalysis.Core.Models"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        x:Class="VideoAnalysis.App.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1600"
        Height="960"
        MinWidth="1180"
        MinHeight="760"
        Title="Video Analytics - Hockey MVP"
        Icon="/Assets/app-icon.ico"
        Background="#0B1220"
        Foreground="#E5EDF9"
        ClipToBounds="True">

  <Window.Resources>
    <converters:StringNullOrEmptyToBoolConverter x:Key="StringNullOrEmptyToBoolConverter"/>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Border.top-menu-bar">
      <Setter Property="Background" Value="#1D1D20"/>
      <Setter Property="Padding" Value="8,4"/>
    </Style>

    <Style Selector="Button.top-menu-item">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="14,6,14,10"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="14,6,14,10"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.top-menu-item /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.top-menu-item:pointerover">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:pointerover">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="Button.top-menu-item:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.top-menu-item:pressed">
      <Setter Property="Background" Value="#45454A"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:checked">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="Button.top-menu-item:pressed /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:checked /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Border.file-menu-popup">
      <Setter Property="Background" Value="#232327"/>
      <Setter Property="BorderBrush" Value="#3A3A3E"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="6"/>
      <Setter Property="BoxShadow" Value="0 8 24 0 #66000000"/>
    </Style>

    <Style Selector="Button.file-menu-item">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="MinWidth" Value="220"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.file-menu-item /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.file-menu-item:pointerover">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="Button.file-menu-item:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.player-button">
      <Setter Property="Background" Value="#24324A"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="Button.player-button:pointerover">
      <Setter Property="Background" Value="#304563"/>
    </Style>

    <Style Selector="Button.player-control-button, ToggleButton.player-control-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="Width" Value="44"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.player-control-button:pointerover, ToggleButton.player-control-button:pointerover">
      <Setter Property="Background" Value="#263246"/>
    </Style>

    <Style Selector="Button.player-control-button:pressed, ToggleButton.player-control-button:checked">
      <Setter Property="Background" Value="#304563"/>
    </Style>

    <Style Selector="Border.player-control-bar">
      <Setter Property="Background" Value="#1D1D20"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="10,6,10,14"/>
      <Setter Property="BorderBrush" Value="#2A3A55"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="Border.player-seek-surface">
      <Setter Property="Height" Value="28"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.player-seek-track">
      <Setter Property="Height" Value="4"/>
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Background" Value="#31435E"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.player-seek-progress">
      <Setter Property="Height" Value="4"/>
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Background" Value="#2F86FF"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Width" Value="0"/>
    </Style>

    <Style Selector="Border.player-volume-surface">
      <Setter Property="Width" Value="20"/>
      <Setter Property="Height" Value="108"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.player-volume-track">
      <Setter Property="Width" Value="4"/>
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Background" Value="#31435E"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="Border.player-volume-progress">
      <Setter Property="Width" Value="4"/>
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Background" Value="#2F86FF"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Bottom"/>
      <Setter Property="Height" Value="0"/>
    </Style>

    <Style Selector="TextBox.player-input">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="CaretBrush" Value="#F7FAFF"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
    </Style>

    <Style Selector="TextBox.player-input:pointerover">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#3A567C"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.player-input:focus">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2F86FF"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.player-input /template/ Border">
      <Setter Property="Background" Value="#162238"/>
    </Style>

    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#111A2B"/>
      <Setter Property="BorderBrush" Value="#24324A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBlock.section-subtitle">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="Border.placeholder-card">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.stats-header-card">
      <Setter Property="Background" Value="#1D1D20"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Padding" Value="18,16"/>
    </Style>

    <Style Selector="Border.stats-logo-placeholder">
      <Setter Property="Width" Value="44"/>
      <Setter Property="Height" Value="44"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Background" Value="#4B5870"/>
      <Setter Property="Opacity" Value="0.9"/>
    </Style>

    <Style Selector="Border.stats-bar-track">
      <Setter Property="Height" Value="8"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Background" Value="#24324A"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="ProgressBar.stats-bar-home">
      <Setter Property="Minimum" Value="0"/>
      <Setter Property="Foreground" Value="#FF2A2A"/>
      <Setter Property="Background" Value="#24324A"/>
      <Setter Property="Height" Value="8"/>
    </Style>

    <Style Selector="ProgressBar.stats-bar-away">
      <Setter Property="Minimum" Value="0"/>
      <Setter Property="Foreground" Value="#2F86FF"/>
      <Setter Property="Background" Value="#24324A"/>
      <Setter Property="Height" Value="8"/>
    </Style>

    <Style Selector="TextBox.event-type-input">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="CaretBrush" Value="#F7FAFF"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#3A567C"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2F86FF"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ Border">
      <Setter Property="Background" Value="#162238"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ ContentControl#PART_Watermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus /template/ ContentControl#PART_Watermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover /template/ ContentControl#PART_Watermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ ContentControl#PART_FloatingWatermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus /template/ ContentControl#PART_FloatingWatermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover /template/ ContentControl#PART_FloatingWatermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ TextBlock#PlaceholderTextBlock">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus /template/ TextBlock#PlaceholderTextBlock">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover /template/ TextBlock#PlaceholderTextBlock">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBlock.input-placeholder">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Margin" Value="12,0,12,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>

    <Style Selector="TextBlock.project-input-placeholder">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Left"/>
      <Setter Property="IsHitTestVisible" Value="False"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBlock.project-input-placeholder.multiline">
      <Setter Property="Margin" Value="0"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style Selector="Button.action-button">
      <Setter Property="Background" Value="#203867"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="Button.action-button:pointerover">
      <Setter Property="Background" Value="#2A4A86"/>
    </Style>

    <Style Selector="Button.event-eye-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#9EB5D4"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="MinWidth" Value="24"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.event-eye-button:pointerover">
      <Setter Property="Background" Value="#24324A"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ListBox.event-type-list">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="ListBox.event-type-list ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Border.panel-tabs">
      <Setter Property="Background" Value="#171A20"/>
      <Setter Property="BorderBrush" Value="#2A3242"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="CornerRadius" Value="8,8,0,0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="ToggleButton.tab-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1,1,1,0"/>
      <Setter Property="Foreground" Value="#A9B5C9"/>
      <Setter Property="Padding" Value="14,12"/>
      <Setter Property="CornerRadius" Value="4,4,0,0"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="ToggleButton.tab-button:pointerover">
      <Setter Property="Background" Value="#1E2737"/>
      <Setter Property="Foreground" Value="#DCE6F5"/>
    </Style>

    <Style Selector="ToggleButton.tab-button:checked">
      <Setter Property="Background" Value="#243B62"/>
      <Setter Property="BorderBrush" Value="#E6ECF8"/>
      <Setter Property="Foreground" Value="#4FA0FF"/>
    </Style>

    <Style Selector="Border.editor-overlay">
      <Setter Property="Background" Value="#A0000000"/>
    </Style>

    <Style Selector="Border.editor-dialog">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="MaxWidth" Value="420"/>
      <Setter Property="Margin" Value="16"/>
    </Style>

    <Style Selector="Border.editor-overlay">
      <Setter Property="Background" Value="#A0000000"/>
    </Style>

    <Style Selector="Border.editor-dialog">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="MaxWidth" Value="420"/>
      <Setter Property="Margin" Value="16"/>
    </Style>

    <Style Selector="Border.new-project-dialog">
      <Setter Property="Background" Value="#2F2F32"/>
      <Setter Property="BorderBrush" Value="#4C566B"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Margin" Value="28"/>
      <Setter Property="MaxWidth" Value="900"/>
    </Style>

    <Style Selector="TextBlock.dialog-title">
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#F5F7FB"/>
    </Style>

    <Style Selector="TextBlock.dialog-subtitle">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="#AAB3C3"/>
    </Style>

    <Style Selector="TextBlock.form-label">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="#E2E8F3"/>
    </Style>

    <Style Selector="TextBox.project-form-input">
      <Setter Property="Background" Value="#1E1F22"/>
      <Setter Property="BorderBrush" Value="#365DA8"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#F5F7FB"/>
      <Setter Property="CaretBrush" Value="#F5F7FB"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
      <Setter Property="Padding" Value="14,12"/>
    </Style>

    <Style Selector="TextBox.project-form-input:pointerover">
      <Setter Property="BorderBrush" Value="#4D79CB"/>
    </Style>

    <Style Selector="TextBox.project-form-input:focus">
      <Setter Property="BorderBrush" Value="#2F86FF"/>
    </Style>

    <Style Selector="TextBox.project-form-input /template/ Border">
      <Setter Property="Background" Value="#1E1F22"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style Selector="Border.project-form-shell">
      <Setter Property="Background" Value="#1E1F22"/>
      <Setter Property="BorderBrush" Value="#365DA8"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="14,12"/>
    </Style>

    <Style Selector="Border.project-form-shell.single-line">
      <Setter Property="Padding" Value="14,8"/>
    </Style>

    <Style Selector="TextBox.project-form-plain-input">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F5F7FB"/>
      <Setter Property="CaretBrush" Value="#F5F7FB"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="TextBox.project-form-plain-input.single-line">
      <Setter Property="MinHeight" Value="0"/>
      <Setter Property="Height" Value="22"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBox.project-form-plain-input /template/ Border">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Button.dialog-secondary-button">
      <Setter Property="Background" Value="#45536D"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F5F7FB"/>
      <Setter Property="Padding" Value="16,14"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style Selector="Button.dialog-secondary-button:pointerover">
      <Setter Property="Background" Value="#546481"/>
    </Style>

    <Style Selector="Button.dialog-primary-button">
      <Setter Property="Background" Value="#3158B5"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F5F7FB"/>
      <Setter Property="Padding" Value="16,14"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style Selector="Button.dialog-primary-button:pointerover">
      <Setter Property="Background" Value="#3A67D1"/>
    </Style>

    <Style Selector="Border.export-window-overlay">
      <Setter Property="Background" Value="#000000E5"/>
    </Style>

    <Style Selector="Border.export-window-dialog">
      <Setter Property="Background" Value="#2A2A2A"/>
      <Setter Property="BorderBrush" Value="#364153"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Width" Value="600"/>
      <Setter Property="MaxWidth" Value="600"/>
      <Setter Property="Margin" Value="28"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.export-window-header">
      <Setter Property="BorderBrush" Value="#364153"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Padding" Value="16"/>
    </Style>

    <Style Selector="TextBlock.export-window-title">
      <Setter Property="FontFamily" Value="Inter"/>
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="TextBlock.export-window-label">
      <Setter Property="FontFamily" Value="Inter"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="#99A1AF"/>
    </Style>

    <Style Selector="ToggleButton.export-option-button">
      <Setter Property="Background" Value="#661E2939"/>
      <Setter Property="BorderBrush" Value="#364153"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="12"/>
      <Setter Property="Foreground" Value="#99A1AF"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FontFamily" Value="Inter"/>
    </Style>

    <!-- Override Fluent theme template directly to prevent orange accent color -->
    <Style Selector="ToggleButton.export-option-button /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{TemplateBinding Background}"/>
      <Setter Property="BorderBrush" Value="{TemplateBinding BorderBrush}"/>
      <Setter Property="BorderThickness" Value="{TemplateBinding BorderThickness}"/>
      <Setter Property="CornerRadius" Value="{TemplateBinding CornerRadius}"/>
      <Setter Property="Foreground" Value="{TemplateBinding Foreground}"/>
    </Style>

    <Style Selector="ToggleButton.export-option-button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#243142"/>
      <Setter Property="BorderBrush" Value="#466078"/>
    </Style>

    <Style Selector="ToggleButton.export-option-button:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#33155DFC"/>
      <Setter Property="BorderBrush" Value="#662B7FFF"/>
    </Style>

    <Style Selector="ToggleButton.export-option-button:checked">
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="ToggleButton.export-option-button.large">
      <Setter Property="MinHeight" Value="70"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="ToggleButton.export-option-button.medium">
      <Setter Property="MinHeight" Value="50"/>
      <Setter Property="FontSize" Value="16"/>
    </Style>

    <Style Selector="ToggleButton.export-option-button.small">
      <Setter Property="MinHeight" Value="42"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="ToggleButton.export-option-button.full">
      <Setter Property="MinHeight" Value="46"/>
      <Setter Property="Padding" Value="12,0,12,0"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="ToggleButton.export-checkbox-row">
      <Setter Property="Background" Value="#661E2939"/>
      <Setter Property="BorderBrush" Value="#364153"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="14,14,16,14"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FontFamily" Value="Inter"/>
      <Setter Property="MinHeight" Value="54"/>
    </Style>

    <Style Selector="ToggleButton.export-checkbox-row /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{TemplateBinding Background}"/>
      <Setter Property="BorderBrush" Value="{TemplateBinding BorderBrush}"/>
      <Setter Property="BorderThickness" Value="{TemplateBinding BorderThickness}"/>
      <Setter Property="CornerRadius" Value="{TemplateBinding CornerRadius}"/>
    </Style>

    <Style Selector="ToggleButton.export-checkbox-row:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#243142"/>
      <Setter Property="BorderBrush" Value="#466078"/>
    </Style>

    <Style Selector="ToggleButton.export-checkbox-row:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#33155DFC"/>
      <Setter Property="BorderBrush" Value="#662B7FFF"/>
    </Style>

    <Style Selector="Border.export-path-shell">
      <Setter Property="Background" Value="#1A1A1A"/>
      <Setter Property="BorderBrush" Value="#364153"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="8,12"/>
    </Style>

    <Style Selector="TextBox.export-path-input">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="CaretBrush" Value="#FFFFFF"/>
      <Setter Property="SelectionBrush" Value="#155DFC"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontFamily" Value="Inter"/>
    </Style>

    <Style Selector="TextBox.export-path-input /template/ Border">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Button.export-footer-secondary">
      <Setter Property="Background" Value="#155DFC"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontFamily" Value="Inter"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.export-footer-secondary /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{TemplateBinding Background}"/>
      <Setter Property="CornerRadius" Value="{TemplateBinding CornerRadius}"/>
    </Style>

    <Style Selector="Button.export-footer-secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#2B70FC"/>
    </Style>

    <Style Selector="Button.export-footer-primary">
      <Setter Property="Background" Value="#9810FA"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontFamily" Value="Inter"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.export-footer-primary /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{TemplateBinding Background}"/>
      <Setter Property="CornerRadius" Value="{TemplateBinding CornerRadius}"/>
    </Style>

    <Style Selector="Button.export-footer-primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#A92DFF"/>
    </Style>

    <Style Selector="Border.startup-screen-overlay">
      <Setter Property="Background" Value="#000000E5"/>
    </Style>

    <Style Selector="Border.startup-launcher">
      <Setter Property="Background" Value="#2A2A2A"/>
      <Setter Property="BorderBrush" Value="#364153"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Margin" Value="28"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.startup-header">
      <Setter Property="BorderBrush" Value="#364153"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Padding" Value="24"/>
    </Style>

    <Style Selector="TextBlock.startup-title">
      <Setter Property="FontSize" Value="24"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="TextBlock.startup-subtitle">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="#99A1AF"/>
    </Style>

    <Style Selector="Button.startup-close-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Width" Value="40"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.startup-close-button:pointerover">
      <Setter Property="Background" Value="#FFFFFF12"/>
    </Style>

    <Style Selector="Button.startup-action-card">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="Border.startup-action-surface">
      <Setter Property="BorderThickness" Value="1.6"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="MinHeight" Value="143.2"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Button.startup-action-card:pointerover Border.startup-action-surface-primary">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#314F73" Offset="0"/>
          <GradientStop Color="#233954" Offset="1"/>
        </LinearGradientBrush>
      </Setter>
    </Style>

    <Style Selector="Button.startup-action-card:pointerover Border.startup-action-surface-secondary">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#4D2E66" Offset="0"/>
          <GradientStop Color="#37204A" Offset="1"/>
        </LinearGradientBrush>
      </Setter>
    </Style>

    <Style Selector="Border.startup-action-icon-shell">
      <Setter Property="Width" Value="48"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="CornerRadius" Value="24"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style Selector="TextBlock.startup-action-title">
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="TextBlock.startup-action-subtitle">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="#99A1AF"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="TextBlock.startup-section-title">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="#99A1AF"/>
      <Setter Property="LetterSpacing" Value="0.7"/>
    </Style>

    <Style Selector="TextBlock.startup-link">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="#51A2FF"/>
    </Style>

    <Style Selector="Button.startup-recent-card-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="Border.recent-project-card">
      <Setter Property="Background" Value="#1A1A1A"/>
      <Setter Property="BorderBrush" Value="#364153"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Width" Value="271.46"/>
      <Setter Property="Height" Value="217.39"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Button.startup-recent-card-button:pointerover Border.recent-project-card">
      <Setter Property="BorderBrush" Value="#4A70C7"/>
      <Setter Property="Background" Value="#232C3A"/>
    </Style>

    <Style Selector="Border.recent-project-preview">
      <Setter Property="Height" Value="151.8"/>
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#253549" Offset="0"/>
          <GradientStop Color="#1E2939" Offset="1"/>
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Border.recent-project-badge">
      <Setter Property="Background" Value="#00000080"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="VerticalAlignment" Value="Bottom"/>
      <Setter Property="Margin" Value="8,0,8,8"/>
    </Style>

    <Style Selector="TextBlock.recent-project-badge-text">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#E5EDF9"/>
      <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <Style Selector="TextBlock.recent-project-title">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="#F5F7FB"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="MaxLines" Value="2"/>
    </Style>

    <Style Selector="TextBlock.recent-project-subtitle">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#99A1AF"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="MaxLines" Value="2"/>
    </Style>

    <Style Selector="TextBlock.recent-project-meta">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="#7E8A9A"/>
      <Setter Property="TextWrapping" Value="NoWrap"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style Selector="Border.startup-empty-state">
      <Setter Property="Background" Value="#1A1A1A"/>
      <Setter Property="BorderBrush" Value="#364153"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="24"/>
      <Setter Property="MinHeight" Value="160"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*" ClipToBounds="True">
    <Border x:Name="TopMenuBar" Grid.Row="0" Classes="top-menu-bar">
      <Grid ColumnDefinitions="Auto,*">
        <StackPanel Orientation="Horizontal" Spacing="2">
          <ToggleButton x:Name="FileMenuButton"
                        Classes="top-menu-item"
                        Checked="OnFileMenuChecked"
                        Content="Файл"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=FileMenuButton}"
                 PlacementTarget="{Binding #FileMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item" Tag="NewProject" Content="Новый проект" Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Tag="OpenProjects" Content="Открыть..." Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Tag="Save" Content="Сохранить" Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Tag="SaveAs" Content="Сохранить как..." Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Tag="Export" Content="Экспорт" Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Tag="Exit" Content="Выход" Click="OnFileMenuActionClick"/>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
          <Button Classes="top-menu-item" Content="Формат"/>
          <ToggleButton x:Name="ViewMenuButton"
                        Classes="top-menu-item"
                        Checked="OnViewMenuChecked"
                        Content="Вид"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=ViewMenuButton}"
                 PlacementTarget="{Binding #ViewMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item"
                        Tag="ToggleTimelinePanel"
                        Click="OnViewMenuActionClick">
                  <Grid ColumnDefinitions="18,*" ColumnSpacing="8">
                    <TextBlock Text="✓"
                               IsVisible="{Binding IsTimelineVisible}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4FA0FF"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Таймлайн"/>
                  </Grid>
                </Button>
                <Button Classes="file-menu-item"
                        Tag="ToggleEventsPanel"
                        Click="OnViewMenuActionClick">
                  <Grid ColumnDefinitions="18,*" ColumnSpacing="8">
                    <TextBlock Text="✓"
                               IsVisible="{Binding IsEventsPanelVisible}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4FA0FF"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Типы событий/События"/>
                  </Grid>
                </Button>
                <Button Classes="file-menu-item"
                        Tag="ToggleAnalysisPanel"
                        Click="OnViewMenuActionClick">
                  <Grid ColumnDefinitions="18,*" ColumnSpacing="8">
                    <TextBlock Text="✓"
                               IsVisible="{Binding IsAnalysisPanelVisible}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4FA0FF"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Плейлисты/Статистика"/>
                  </Grid>
                </Button>
              </StackPanel>
            </Border>
          </Popup>
          <ToggleButton x:Name="HelpMenuButton"
                        Classes="top-menu-item"
                        Checked="OnHelpMenuChecked"
                        Content="Помощь"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=HelpMenuButton}"
                 PlacementTarget="{Binding #HelpMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item" Content="Документация" Click="OnHelpMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Горячие клавиши" Click="OnHelpMenuActionClick"/>
                <Button Classes="file-menu-item" Content="О программе" Click="OnHelpMenuActionClick"/>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>
      </Grid>
    </Border>

    <Grid x:Name="MainLayoutGrid" Grid.Row="1" Margin="12" ClipToBounds="True">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="3.2*" MinWidth="420"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="1.05*" MinWidth="250"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="1.45*" MinWidth="280"/>
      </Grid.ColumnDefinitions>

      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="260"/>
        <RowDefinition Height="6"/>
        <RowDefinition Height="240" MinHeight="170"/>
      </Grid.RowDefinitions>

      <Border x:Name="PlayerPanel" Grid.Row="0" Grid.Column="0" Classes="panel">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="14" ClipToBounds="True">
          <StackPanel Spacing="4">
            <TextBlock Classes="section-title" Text="Плеер"/>
            <TextBlock Classes="section-subtitle" Text="{Binding StatusMessage}"/>
          </StackPanel>

          <Border x:Name="PlayerSurfaceHost"
                  Grid.Row="1"
                  Background="#050B14"
                  BorderBrush="#2A3A55"
                  BorderThickness="1"
                  CornerRadius="10"
                  ClipToBounds="True"
                  IsVisible="{Binding IsPlayerSurfaceVisible}">
            <Grid>
              <vlc:VideoView x:Name="PlayerView"
                             MediaPlayer="{Binding MediaPlayer}"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"/>

              <Border Background="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ZIndex="1"
                      PointerPressed="OnPlayerSurfacePointerPressed"/>

              <Border HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      Margin="14"
                      Background="#B3000000"
                      CornerRadius="8"
                      Padding="10,6">
                <TextBlock Text="{Binding CurrentTimeText}"
                           Foreground="#F7FAFF"
                           FontSize="13"
                           FontWeight="Medium"/>
              </Border>
            </Grid>
          </Border>

          <Border Grid.Row="2" Classes="player-control-bar">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto,Auto"
                  ColumnSpacing="10"
                  VerticalAlignment="Center">
              <Button Grid.Column="0"
                      Classes="player-control-button"
                      Command="{Binding StepBackwardCommand}">
                <TextBlock Text="⏮"
                           FontFamily="Segoe UI Symbol"
                           FontSize="18"/>
              </Button>

              <Button Grid.Column="1"
                      Classes="player-control-button"
                      Command="{Binding TogglePlayPauseCommand}">
                <Grid Width="18"
                      Height="18">
                  <Path Data="M 2 1 L 16 9 L 2 17 Z"
                        Fill="#F7FAFF"
                        Stretch="Uniform"
                        IsVisible="{Binding !IsPlaying}"/>
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="4"
                        IsVisible="{Binding IsPlaying}">
                    <Border Width="4"
                            Height="16"
                            CornerRadius="1"
                            Background="#F7FAFF"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    <Border Grid.Column="1"
                            Width="4"
                            Height="16"
                            CornerRadius="1"
                            Background="#F7FAFF"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                  </Grid>
                </Grid>
              </Button>

              <Button Grid.Column="2"
                      Classes="player-control-button"
                      Command="{Binding StepForwardCommand}">
                <TextBlock Text="⏭"
                           FontFamily="Segoe UI Symbol"
                           FontSize="18"/>
              </Button>

              <Border Grid.Column="3"
                      Classes="player-seek-surface"
                      PointerPressed="OnSeekBarPointerPressed"
                      PointerMoved="OnSeekBarPointerMoved"
                      PointerReleased="OnSeekBarPointerReleased">
                <Grid x:Name="SeekBarRoot"
                      Height="18"
                      VerticalAlignment="Center"
                      SizeChanged="OnSeekBarSizeChanged">
                  <Border Classes="player-seek-track"/>
                  <Border x:Name="SeekBarProgress" Classes="player-seek-progress"/>
                  <Ellipse x:Name="SeekBarThumb"
                           Width="18"
                           Height="18"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Fill="#2F86FF"/>
                </Grid>
              </Border>

              <TextBlock Grid.Column="4"
                         VerticalAlignment="Center"
                         Foreground="#D9E5F8"
                         FontSize="14"
                         FontWeight="SemiBold">
                <Run Text="{Binding CurrentTimeText}"/>
                <Run Text=" / "/>
                <Run Text="{Binding DurationTimeText}"/>
              </TextBlock>

              <ToggleButton x:Name="SpeedMenuButton"
                            Grid.Column="5"
                            Classes="player-control-button"
                            Content="{Binding PlaybackRateText}"/>
              <Popup IsOpen="{Binding IsChecked, ElementName=SpeedMenuButton}"
                     PlacementTarget="{Binding #SpeedMenuButton}"
                     Placement="Top"
                     HorizontalOffset="0"
                     VerticalOffset="-8">
                <Border Classes="file-menu-popup" Padding="6">
                  <ItemsControl ItemsSource="{Binding PlaybackRateOptions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Classes="file-menu-item"
                                MinWidth="86"
                                Command="{Binding #RootWindow.DataContext.SetPlaybackRateCommand}"
                                CommandParameter="{Binding}"
                                Click="OnPlaybackRateMenuActionClick"
                                Content="{Binding}"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>
              </Popup>

              <ToggleButton x:Name="VolumeButton"
                            Grid.Column="6"
                            Classes="player-control-button">
                <TextBlock Text="{Binding VolumeGlyph}" FontFamily="Segoe UI Symbol" FontSize="18"/>
              </ToggleButton>
              <Popup IsOpen="{Binding IsChecked, ElementName=VolumeButton}"
                     PlacementTarget="{Binding #VolumeButton}"
                     Placement="Top"
                     HorizontalOffset="-4"
                     VerticalOffset="-8">
                <Border Classes="file-menu-popup" Padding="10,12">
                  <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <Button Classes="player-control-button"
                            HorizontalAlignment="Center"
                            Command="{Binding ToggleMuteCommand}">
                      <TextBlock Text="{Binding VolumeGlyph}" FontFamily="Segoe UI Symbol" FontSize="18"/>
                    </Button>
                    <Border Classes="player-volume-surface"
                            PointerPressed="OnVolumeBarPointerPressed"
                            PointerMoved="OnVolumeBarPointerMoved"
                            PointerReleased="OnVolumeBarPointerReleased">
                      <Grid x:Name="VolumeBarRoot"
                            Width="20"
                            Height="108">
                        <Border Classes="player-volume-track" Margin="0,9"/>
                        <Border x:Name="VolumeBarProgress" Classes="player-volume-progress" Margin="0,9"/>
                        <Ellipse x:Name="VolumeBarThumb"
                                 Width="18"
                                 Height="18"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Top"
                                 Fill="#2F86FF"/>
                      </Grid>
                    </Border>
                  </StackPanel>
                </Border>
              </Popup>

              <Button Grid.Column="7"
                      Classes="player-control-button"
                      Click="OnToggleFullscreenClick">
                <TextBlock Text="⛶" FontFamily="Segoe UI Symbol" FontSize="18"/>
              </Button>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <GridSplitter x:Name="EventsPanelSplitter" Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="1"
                    Width="6"
                    Background="#24324A"
                    ResizeDirection="Columns"
                    HorizontalAlignment="Stretch"/>

      <Border x:Name="EventsPanel" Grid.Row="0"
              Grid.RowSpan="3"
              Grid.Column="2"
              Classes="panel"
              Padding="0"
              IsVisible="{Binding IsEventsPanelVisible}">
        <Grid>
          <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        ClipToBounds="True">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14" ClipToBounds="True">
              <Border Grid.Row="0" Classes="panel-tabs">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
                  <ToggleButton Grid.Column="0"
                                Classes="tab-button"
                                IsChecked="{Binding IsEventTypesTabSelected}"
                                Command="{Binding SelectEventsPanelTabCommand}"
                                CommandParameter="EventTypes"
                                Content="Типы событий"/>
                  <ToggleButton Grid.Column="1"
                                Classes="tab-button"
                                IsChecked="{Binding IsEventsTabSelected}"
                                Command="{Binding SelectEventsPanelTabCommand}"
                                CommandParameter="Events"
                                Content="События"/>
                </Grid>
              </Border>

              <Grid Grid.Row="1"
                    Grid.RowSpan="3"
                    Margin="18,0,18,18"
                    RowDefinitions="Auto,*,Auto"
                    RowSpacing="10"
                    IsVisible="{Binding IsEventsTabSelected}">
                <TextBlock Text="События"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <ListBox Grid.Row="1"
                         Classes="event-type-list"
                         ItemsSource="{Binding TagEvents}"
                         SelectedItem="{Binding SelectedTagEvent, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#1A2640"
                              CornerRadius="8"
                              Padding="12,10"
                              DoubleTapped="OnTagEventItemDoubleTapped">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <TextBlock Text="{Binding PresetName}"
                                       FontWeight="SemiBold"
                                       Foreground="#F7FAFF"/>
                            <StackPanel Grid.Column="1"
                                        Spacing="2"
                                        HorizontalAlignment="Right">
                              <TextBlock Text="{Binding TeamSide}"
                                         Foreground="#9EB5D4"
                                         FontWeight="SemiBold"
                                         HorizontalAlignment="Right"/>
                              <Button Classes="event-eye-button"
                                      HorizontalAlignment="Right"
                                      Click="OnTagEventPreviewClick">
                                <TextBlock Text="👁" FontSize="12"/>
                              </Button>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Classes="event-eye-button"
                                    Command="{Binding #RootWindow.DataContext.TogglePlaylistSelectionCommand}"
                                    CommandParameter="{Binding}"
                                    VerticalAlignment="Top">
                              <TextBlock Text="{Binding PlaylistToggleGlyph}"
                                         FontSize="16"
                                         FontWeight="SemiBold"/>
                            </Button>
                          </Grid>
                          <TextBlock Grid.Row="1"
                                     Foreground="#C9D7EB"
                                     Text="{Binding StartFrame, StringFormat='Старт: {0}'}"/>
                          <TextBlock Grid.Row="2"
                                     Foreground="#C9D7EB"
                                     Text="{Binding EndFrame, StringFormat='Конец: {0}'}"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="2" RowDefinitions="Auto,Auto" RowSpacing="10">
                  <Button Grid.Row="0"
                          Classes="action-button"
                          Command="{Binding OpenNewTagEventEditorCommand}"
                          Content="Новое событие"/>
                  <Button Grid.Row="1"
                          Classes="action-button"
                          Command="{Binding OpenAddToPlaylistDialogCommand}"
                          IsEnabled="{Binding CanOpenAddToPlaylistDialog}"
                          Content="Добавить в плейлист"/>
                </Grid>
              </Grid>

              <Grid Grid.Row="1"
                    Margin="18,0,18,0"
                    IsVisible="{Binding IsEventTypesTabSelected}">
                <StackPanel Spacing="10">
                  <TextBlock Text="Типы событий"
                             FontSize="16"
                             FontWeight="SemiBold"/>
                  <ListBox Classes="event-type-list"
                           ItemsSource="{Binding EventTypeItems}"
                           SelectedItem="{Binding SelectedEventTypeItem, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="items:EventTypeItemViewModel">
                        <Border Background="{Binding ColorHex}"
                                CornerRadius="8"
                                Padding="12,10"
                                DoubleTapped="OnEventTypeItemDoubleTapped">
                          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <StackPanel Spacing="2">
                              <TextBlock Text="{Binding Name}"
                                         FontWeight="SemiBold"
                                         Foreground="#F7FAFF"/>
                              <TextBlock Text="{Binding Category}"
                                         Foreground="#DCE6F5"
                                         FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Spacing="4"
                                        HorizontalAlignment="Right">
                              <TextBlock Text="{Binding EventCount}"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center"
                                         Foreground="#F7FAFF"
                                         FontWeight="SemiBold"/>
                              <TextBlock Text="{Binding Hotkey}"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center"
                                         Foreground="#DCE6F5"
                                         FontSize="12"
                                         FontWeight="SemiBold"/>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </StackPanel>
              </Grid>

              <Grid Grid.Row="3"
                    ColumnDefinitions="*"
                    ColumnSpacing="10"
                    Margin="18,0,18,18"
                    IsVisible="{Binding IsEventTypesTabSelected}">
                <Button Grid.Column="0"
                        Classes="action-button"
                        Command="{Binding OpenNewPresetEditorCommand}"
                        Content="Новый тип событий"/>
              </Grid>
            </Grid>
          </ScrollViewer>
          <Border Classes="editor-overlay"
                  IsVisible="{Binding IsAddToPlaylistDialogOpen}">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
              <Border Classes="editor-dialog"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Text="Добавить в плейлист"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F7FAFF"/>
                    <Button Grid.Column="1"
                            Classes="player-control-button"
                            Command="{Binding CloseAddToPlaylistDialogCommand}"
                            Content="X"/>
                  </Grid>

                  <StackPanel Grid.Row="1" Spacing="10">
                    <TextBlock Text="Выбранные события будут добавлены в существующий плейлист."
                               Foreground="#AAB9CF"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SelectedPlaylistEventCount, StringFormat=Будет добавлено событий: {0}}"
                               Foreground="#DCE6F5"/>
                    <ComboBox ItemsSource="{Binding Playlists}"
                              SelectedItem="{Binding SelectedTargetPlaylistForAdd, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="items:PlaylistSummaryItemViewModel">
                          <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>

                  <Grid Grid.Row="2"
                        ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Classes="action-button"
                            Command="{Binding AddSelectedEventsToPlaylistCommand}"
                            IsEnabled="{Binding CanAddSelectedEventsToPlaylist}"
                            Content="Добавить"/>
                    <Button Grid.Column="1"
                            Classes="action-button"
                            Command="{Binding CloseAddToPlaylistDialogCommand}"
                            Content="Закрыть"/>
                  </Grid>
                </Grid>
              </Border>
            </Grid>
          </Border>


          <Border Classes="editor-overlay"
                  IsVisible="{Binding IsPresetEditorOpen}">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
              <Border Classes="editor-dialog"
                      x:Name="PresetEditorDialog"
                      Focusable="True"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding PresetEditorTitle}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F7FAFF"/>
                    <Button x:Name="PresetEditorCloseButton"
                            Grid.Column="1"
                            Classes="player-control-button"
                            Command="{Binding ClosePresetEditorCommand}"
                            Content="X"/>
                  </Grid>

                  <StackPanel Grid.Row="1" Spacing="10">
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding EventTypeName}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Название"
                                 IsVisible="{Binding EventTypeName, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding EventTypeHotkey, UpdateSourceTrigger=PropertyChanged}"
                               TextInput="OnEventTypeHotkeyTextInput"
                               TextChanged="OnEventTypeHotkeyTextChanged"
                               KeyDown="OnEventTypeHotkeyEditorKeyDown"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Hotkey"
                                 IsVisible="{Binding EventTypeHotkey, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding EventTypeColor}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="#RRGGBB"
                                 IsVisible="{Binding EventTypeColor, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding EventTypeCategory}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Категория"
                                 IsVisible="{Binding EventTypeCategory, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding EventTypeIconKey}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Icon key"
                                 IsVisible="{Binding EventTypeIconKey, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                      <StackPanel Spacing="6">
                        <TextBlock Text="Pre-roll"
                                   Foreground="#AAB9CF"
                                   FontSize="12"/>
                        <TextBox Classes="event-type-input"
                                 Text="{Binding EventTypePreRollFrames}"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1"
                                  Spacing="6">
                        <TextBlock Text="Post-roll"
                                   Foreground="#AAB9CF"
                                   FontSize="12"/>
                        <TextBox Classes="event-type-input"
                                 Text="{Binding EventTypePostRollFrames}"/>
                      </StackPanel>
                    </Grid>
                    <CheckBox Content="Показывать в статистике"
                              IsChecked="{Binding EventTypeShowInStatistics}"
                              Foreground="#DCE6F5"/>
                  </StackPanel>

                  <Grid Grid.Row="2"
                        ColumnDefinitions="*,*,*"
                        ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Classes="action-button"
                            Command="{Binding SavePresetCommand}"
                            Content="Сохранить"/>
                    <Button Grid.Column="1"
                            Classes="action-button"
                            IsVisible="{Binding IsEditingPreset}"
                            Command="{Binding DeletePresetCommand}"
                            IsEnabled="{Binding CanDeleteEditedPreset}"
                            Content="Удалить"/>
                    <Button Grid.Column="2"
                            Classes="action-button"
                            Command="{Binding ClosePresetEditorCommand}"
                            Content="Закрыть"/>
                  </Grid>
                </Grid>
              </Border>
            </Grid>
          </Border>

          <Border Classes="editor-overlay"
                  IsVisible="{Binding IsTagEventEditorOpen}">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
              <Border Classes="editor-dialog"
                      x:Name="TagEventEditorDialog"
                      Focusable="True"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding TagEventEditorTitle}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F7FAFF"/>
                    <Button x:Name="TagEventEditorCloseButton"
                            Grid.Column="1"
                            Classes="player-control-button"
                            Command="{Binding CloseTagEventEditorCommand}"
                            Content="X"/>
                  </Grid>

                  <StackPanel Grid.Row="1" Spacing="10">
                    <ComboBox ItemsSource="{Binding TagPresets}"
                              SelectedItem="{Binding SelectedPreset, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:TagPreset">
                          <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <TextBox Classes="event-type-input"
                               Watermark="Старт"
                               IsReadOnly="True"
                               Text="{Binding TagStartFrame}"/>
                      <Button Grid.Column="1"
                              Classes="action-button"
                              Command="{Binding UseCurrentFrameForTagStartCommand}"
                              Content="Текущий"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <TextBox Classes="event-type-input"
                               Watermark="Конец"
                               IsReadOnly="True"
                               Text="{Binding TagEndFrame}"/>
                      <Button Grid.Column="1"
                              Classes="action-button"
                              Command="{Binding UseCurrentFrameForTagEndCommand}"
                              Content="Текущий"/>
                    </Grid>
                    <ComboBox ItemsSource="{Binding EventTeamSides}"
                              SelectedItem="{Binding TagTeamSide, Mode=TwoWay}"/>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding TagPlayer}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Игрок"
                                 IsVisible="{Binding TagPlayer, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding TagPeriod}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Период"
                                 IsVisible="{Binding TagPeriod, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding TagNotes}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Заметки"
                                 IsVisible="{Binding TagNotes, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                  </StackPanel>

                  <Grid Grid.Row="2"
                        ColumnDefinitions="*,*,*"
                        ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Classes="action-button"
                            Command="{Binding AddTagCommand}"
                            Content="Сохранить"/>
                    <Button Grid.Column="1"
                            Classes="action-button"
                            IsVisible="{Binding IsEditingTagEvent}"
                            Command="{Binding DeleteSelectedTagCommand}"
                            IsEnabled="{Binding CanDeleteEditedTagEvent}"
                            Content="Удалить"/>
                    <Button Grid.Column="2"
                            Classes="action-button"
                            Command="{Binding CloseTagEventEditorCommand}"
                            Content="Закрыть"/>
                  </Grid>
                </Grid>
              </Border>
            </Grid>
          </Border>
        </Grid>
      </Border>
      <GridSplitter x:Name="AnalysisPanelSplitter" Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="3"
                    Width="6"
                    Background="#24324A"
                    ResizeDirection="Columns"
                    HorizontalAlignment="Stretch"
                    IsVisible="{Binding IsAnalysisPanelVisible}"/>

      <Border x:Name="AnalysisPanel" Grid.Row="0"
              Grid.RowSpan="3"
              Grid.Column="4"
              Classes="panel"
              Padding="0"
              IsVisible="{Binding IsAnalysisPanelVisible}">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Classes="panel-tabs">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
              <ToggleButton Grid.Column="0"
                            Classes="tab-button"
                            IsChecked="{Binding IsPlaylistsTabSelected}"
                            Command="{Binding SelectRightPanelTabCommand}"
                            CommandParameter="Playlists"
                            Content="Плейлисты"/>
              <ToggleButton Grid.Column="1"
                            Classes="tab-button"
                            IsChecked="{Binding IsStatisticsTabSelected}"
                            Command="{Binding SelectRightPanelTabCommand}"
                            CommandParameter="Statistics"
                            Content="Статистика"/>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        ClipToBounds="True"
                        IsVisible="{Binding IsPlaylistsTabSelected}">
            <Grid RowDefinitions="Auto,Auto,Auto,*"
                  RowSpacing="14"
                  ClipToBounds="True"
                  Margin="18,18,18,18">
              <StackPanel Spacing="4">
                <TextBlock Classes="section-title" Text="Плейлисты"/>
                <TextBlock Classes="section-subtitle" Text="Собирайте подборки из отмеченных событий, открывайте их в плеере и готовьте к экспорту."/>
              </StackPanel>

              <Border Grid.Row="1"
                      Classes="placeholder-card">
                <StackPanel Spacing="10">
  <TextBlock Text="Конструктор подборки"
             FontSize="16"
             FontWeight="SemiBold"/>
  <Grid>
    <TextBox Classes="event-type-input"
             Text="{Binding PlaylistName}"/>
    <TextBlock Classes="input-placeholder"
               Text="Название плейлиста"
               IsVisible="{Binding PlaylistName, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
  </Grid>
  <Grid>
    <TextBox Classes="event-type-input"
             Text="{Binding PlaylistDescription}"
             AcceptsReturn="True"
             TextWrapping="Wrap"
             Height="70"/>
    <TextBlock Classes="input-placeholder"
               Text="Описание подборки"
               VerticalAlignment="Top"
               Margin="12,12,12,12"
               IsVisible="{Binding PlaylistDescription, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
  </Grid>
  <TextBlock Text="{Binding SelectedPlaylistEventCount, StringFormat=Выбрано событий: {0}}"
             Foreground="#AAB9CF"/>
  <Button Classes="action-button"
          Command="{Binding CreatePlaylistCommand}"
          IsEnabled="{Binding CanCreatePlaylist}"
          Content="Создать плейлист"/>
</StackPanel>
              </Border>

              <Border Grid.Row="2"
                      Classes="placeholder-card">
                <StackPanel Spacing="10">
                  <TextBlock Text="Сохраненные плейлисты"
                             FontSize="16"
                             FontWeight="SemiBold"/>
                  <ListBox Classes="event-type-list"
                           ItemsSource="{Binding Playlists}"
                           SelectedItem="{Binding SelectedPlaylist, Mode=TwoWay}"
                           MaxHeight="220">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="items:PlaylistSummaryItemViewModel">
                        <Border Background="#162238"
                                BorderBrush="#2B3C59"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10">
                          <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       Foreground="#F7FAFF"/>
                            <TextBlock Text="{Binding Description}"
                                       Foreground="#C9D7EB"
                                       TextWrapping="Wrap"
                                       MaxLines="2"/>
                            <TextBlock Text="{Binding UpdatedAtText}"
                                       Foreground="#8FA3BF"
                                       FontSize="12"/>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                  <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Classes="action-button"
                            Command="{Binding OpenSelectedPlaylistCommand}"
                            IsEnabled="{Binding CanOpenSelectedPlaylist}"
                            Content="Открыть"/>
                    <Button Grid.Column="1"
                            Classes="action-button"
                            Command="{Binding DeleteSelectedPlaylistCommand}"
                            IsEnabled="{Binding CanDeleteSelectedPlaylist}"
                            Content="Удалить"/>
                    <Button Grid.Column="2"
                            Classes="action-button"
                            Command="{Binding OpenExportDialogForPlaylistCommand}"
                            IsEnabled="{Binding CanPlayActivePlaylist}"
                            Content="Экспорт"/>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Grid.Row="3"
                      Classes="placeholder-card">
                <Grid RowDefinitions="Auto,Auto,*,Auto"
                      RowSpacing="10">
                  <TextBlock Text="Текущая подборка"
                             FontSize="16"
                             FontWeight="SemiBold"/>
                  <TextBlock Grid.Row="1"
                             Text="{Binding ClipSummary}"
                             Foreground="#AAB9CF"/>

                  <ListBox Grid.Row="2"
                           Classes="event-type-list"
                           ItemsSource="{Binding PlaylistItems}"
                           SelectedItem="{Binding SelectedPlaylistItem, Mode=TwoWay}"
                           IsVisible="{Binding HasPlaylistItems}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="items:PlaylistClipItemViewModel">
                        <Border Background="#162238"
                                BorderBrush="#2B3C59"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10">
                          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding Label}"
                                         FontWeight="SemiBold"
                                         Foreground="#F7FAFF"/>
                              <TextBlock Text="{Binding FrameRangeText}"
                                         Foreground="#C9D7EB"/>
                              <TextBlock Text="{Binding Player}"
                                         Foreground="#8FA3BF"
                                         FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="event-eye-button"
                                    Command="{Binding #RootWindow.DataContext.SeekToPlaylistItemCommand}"
                                    CommandParameter="{Binding}">
                              <TextBlock Text="▶"
                                         FontSize="12"/>
                            </Button>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <TextBlock Grid.Row="2"
                             Text="Пока нет открытого плейлиста."
                             Foreground="#AAB9CF"
                             IsVisible="{Binding HasNoPlaylistItems}"/>

                  <Grid Grid.Row="3"
                        ColumnDefinitions="Auto">
                    <Button Grid.Column="0"
                            Classes="action-button"
                            Command="{Binding PlayActivePlaylistCommand}"
                            IsEnabled="{Binding CanPlayActivePlaylist}"
                            Content="Воспроизвести"/>
                  </Grid>
                </Grid>
              </Border>
            </Grid>
          </ScrollViewer>

          <ScrollViewer Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        ClipToBounds="True"
                        IsVisible="{Binding IsStatisticsTabSelected}">
            <Grid RowDefinitions="Auto,*"
                  ClipToBounds="True">
              <Border Grid.Row="0" Classes="stats-header-card">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,*,Auto" ColumnSpacing="12">
                    <Border Classes="stats-logo-placeholder"/>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="2">
                      <TextBlock Text="ХОЗЯЕВА"
                                 FontSize="14"
                                 Foreground="#AAB9CF"
                                 FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding HomeTeamDisplayName}"
                                 FontSize="12"
                                 Foreground="#8FA3BF"
                                 MaxWidth="120"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="{Binding HomeScore}"
                               VerticalAlignment="Center"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#F7FAFF"/>
                    <TextBlock Grid.Column="3"
                               Text="-"
                               VerticalAlignment="Center"
                               FontSize="20"
                               Foreground="#AAB9CF"/>
                    <TextBlock Grid.Column="4"
                               Text="{Binding AwayScore}"
                               VerticalAlignment="Center"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#F7FAFF"/>
                    <StackPanel Grid.Column="5"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="2">
                      <TextBlock Text="ГОСТИ"
                                 HorizontalAlignment="Right"
                                 FontSize="14"
                                 Foreground="#AAB9CF"
                                 FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding AwayTeamDisplayName}"
                                 HorizontalAlignment="Right"
                                 FontSize="12"
                                 Foreground="#8FA3BF"
                                 MaxWidth="120"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Border Grid.Column="6" Classes="stats-logo-placeholder"/>
                  </Grid>
                </Border>

              <ItemsControl Grid.Row="1"
                            ItemsSource="{Binding StatisticsItems}"
                            Margin="18,18,18,18">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="items:StatisticsBarItemViewModel">
                    <StackPanel Spacing="8" Margin="0,0,0,16">
                      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <TextBlock Text="{Binding HomeCount}"
                                   Foreground="#8FA3BF"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   HorizontalAlignment="Center"
                                   Foreground="#AAB9CF"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding AwayCount}"
                                   Foreground="#8FA3BF"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                      </Grid>
                      <Grid ColumnDefinitions="*,12,*" ColumnSpacing="0">
                        <Border Grid.Column="0" Classes="stats-bar-track">
                          <ProgressBar Classes="stats-bar-home"
                                       Maximum="{Binding MaxCount}"
                                       Value="{Binding HomeCount}"
                                       FlowDirection="RightToLeft"/>
                        </Border>
                        <Border Grid.Column="2" Classes="stats-bar-track">
                          <ProgressBar Classes="stats-bar-away"
                                       Maximum="{Binding MaxCount}"
                                       Value="{Binding AwayCount}"/>
                        </Border>
                      </Grid>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </ScrollViewer>
        </Grid>
      </Border>
      <GridSplitter x:Name="TimelinePanelSplitter" Grid.Row="1"
                    Grid.Column="0"
                    Height="6"
                    Background="#24324A"
                    ResizeDirection="Rows"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>

      <Border x:Name="TimelinePanel"
              Grid.Row="2"
              Grid.Column="0"
              Background="#1A1A1A"
              BorderBrush="#1E2939"
              BorderThickness="1,1,1,0"
              CornerRadius="10"
              Padding="1,0,0,0"
              ClipToBounds="True"
              IsVisible="{Binding IsTimelineVisible}">
        <Grid RowDefinitions="47.65625,*"
              Background="#1A1A1A"
              ClipToBounds="True">
          <Border Grid.Row="0"
                  Background="#1A1A1A"
                  BorderBrush="#1E2939"
                  BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*">
            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
              <TextBlock Text="ТАЙМЛАЙН"
                         Foreground="#99A1AF"
                         FontSize="14"
                         FontWeight="Medium"/>
              <TextBlock Text="{Binding TimelineHeaderTimeText}"
                         Foreground="#94A3B8"
                         FontSize="14"/>
            </StackPanel>

            <ToggleButton x:Name="TimelineFilterButton"
                          Grid.Column="1"
                          Width="155.5"
                          Height="30.65625"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          CornerRadius="4"
                          Background="#1E2939"
                          BorderBrush="#1E2939"
                          BorderThickness="1"
                          IsChecked="{Binding IsTimelineFilterPopupOpen}">
              <Grid ColumnDefinitions="Auto,*,Auto"
                    Margin="12,0"
                    VerticalAlignment="Center">
                <Canvas Width="14"
                        Height="14"
                        VerticalAlignment="Center">
                  <Path Data="M7.99964 17c-0.00009 0.18583 0.05161 0.36801 0.14929 0.5261 0.09768 0.15809 0.23748 0.28583 0.40371 0.3689l2 1c0.1525 0.0762 0.32194 0.11215 0.49224 0.10444 0.1703-0.00771 0.3358-0.05883 0.48079-0.14851 0.14498-0.08968 0.26464-0.21493 0.34759-0.36386 0.08296-0.14893 0.12646-0.3166 0.12638-0.48707l0-7c0.00022-0.49562 0.18446-0.9735 0.517-1.341l7.223-7.989c0.12946-0.14344 0.21459-0.32132 0.2451-0.51212 0.03051-0.1908 0.00509-0.38635-0.0732-0.56301-0.07828-0.17666-0.20606-0.32685-0.36789-0.43242-0.16183-0.10557-0.35079-0.162-0.54401-0.16245l-18 0c-0.19339 0.00007-0.38262 0.05622-0.54475 0.16164-0.16213 0.10542-0.29022 0.25559-0.36875 0.43232-0.07852 0.17673-0.10412 0.37245-0.07368 0.56343 0.03044 0.19098 0.1156 0.36904 0.24518 0.51261l7.225 7.989c0.33254 0.3675 0.51678 0.84538 0.517 1.341l0 6z"
                        Stroke="#FFFFFF"
                        StrokeThickness="1.1666666"
                        StrokeLineCap="Round"
                        StrokeJoin="Round"
                        Width="11.66508"
                        Height="11.083605"
                        Stretch="Fill">
                    <Path.RenderTransform>
                      <TranslateTransform X="1.1669" Y="1.75"/>
                    </Path.RenderTransform>
                  </Path>
                </Canvas>
                <TextBlock Grid.Column="1"
                           Text="{Binding TimelineFilterButtonText}"
                           Foreground="#FFFFFF"
                           FontSize="14"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="4,0"/>
                <Canvas Grid.Column="2"
                        Width="12"
                        Height="12"
                        VerticalAlignment="Center">
                  <Path Data="M0 0l6 6 6-6"
                        Stroke="#FFFFFF"
                        StrokeThickness="1"
                        StrokeLineCap="Round"
                        StrokeJoin="Round"
                        Width="6"
                        Height="3"
                        Stretch="Fill">
                    <Path.RenderTransform>
                      <TranslateTransform X="3" Y="4.5"/>
                    </Path.RenderTransform>
                  </Path>
                </Canvas>
              </Grid>
            </ToggleButton>

            <Popup PlacementTarget="{Binding #TimelineFilterButton}"
                   IsOpen="{Binding IsTimelineFilterPopupOpen}"
                   Placement="Bottom"
                   HorizontalOffset="0"
                   VerticalOffset="8">
              <Border Background="#252525"
                      BorderBrush="#1E2939"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="10"
                      Width="220"
                      MaxHeight="260">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <ItemsControl ItemsSource="{Binding TimelineFilters}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10"
                              Height="32">
                          <Ellipse Width="8"
                                   Height="8"
                                   Fill="{Binding ColorHex}"
                                   VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Name}"
                                     Foreground="#D1D5DC"
                                     FontSize="14"
                                     VerticalAlignment="Center"/>
                          <CheckBox Grid.Column="2"
                                    IsChecked="{Binding IsVisible}"
                                    VerticalAlignment="Center"/>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Border>
            </Popup>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        ClipToBounds="True">
            <Grid ColumnDefinitions="128,Auto"
                  Background="#1A1A1A">
              <Grid Grid.Column="0"
                    Background="#1A1A1A">
                <Grid RowDefinitions="24,*">
                  <Border Grid.Row="0"
                          Background="#252525"
                          BorderBrush="#1E2939"
                          BorderThickness="0,0,1,1">
                    <TextBlock Text="Время"
                               Margin="16,1,0,0"
                               Foreground="#6A7282"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                  </Border>
                  <ItemsControl Grid.Row="1"
                                ItemsSource="{Binding TimelineRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="items:TimelineRowItemViewModel">
                        <Border Height="40"
                                Background="#1A1A1A"
                                BorderBrush="#1E293980"
                                BorderThickness="0,0,1,1">
                          <StackPanel Orientation="Horizontal"
                                      Spacing="8"
                                      VerticalAlignment="Center"
                                      Margin="16,0,0,0">
                            <Border Width="8"
                                    Height="8"
                                    CornerRadius="33554400"
                                    Background="{Binding ColorHex}"/>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#D1D5DC"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>
              </Grid>

              <ScrollViewer x:Name="TimelineHorizontalScrollViewer" Grid.Column="1"
                            HorizontalScrollBarVisibility="Visible"
                            VerticalScrollBarVisibility="Disabled"
                            ClipToBounds="True">
                <Grid Width="{Binding TimelineCanvasWidth}"
                      HorizontalAlignment="Left"
                      Background="#1A1A1A">
                  <Grid RowDefinitions="24,*">
                    <Border Grid.Row="0"
                            Background="#252525"
                            BorderBrush="#1E2939"
                            BorderThickness="0,0,0,1"/>

                    <ItemsControl Grid.Row="0"
                                  Classes="timeline-ticks"
                                  ItemsSource="{Binding TimelineTicks}"
                                  IsHitTestVisible="False">
                      <ItemsControl.Styles>
                        <Style Selector="ItemsControl.timeline-ticks > ContentPresenter">
                          <Setter Property="Canvas.Left" Value="{ReflectionBinding DataContext.Left, RelativeSource={RelativeSource Self}}"/>
                        </Style>
                      </ItemsControl.Styles>
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <Canvas Height="24"
                                  Width="{Binding DataContext.TimelineCanvasWidth, ElementName=RootWindow}"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="items:TimelineTickItemViewModel">
                          <Grid Width="52"
                                Height="24"
                                IsHitTestVisible="False">
                            <Border Width="1"
                                    Height="8"
                                    Background="#364153"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding Label}"
                                       Foreground="#E2E8F0"
                                       FontSize="13"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Margin="4,0,0,0"/>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding TimelineRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="items:TimelineRowItemViewModel">
                          <Grid Height="40"
                                Background="#1A1A1A"
                                ClipToBounds="True">
                            <Border BorderBrush="#1E293980"
                                    BorderThickness="0,0,0,1"/>
                            <Canvas Height="40"
                                    ClipToBounds="True">
                              <ItemsControl Classes="timeline-grid-lines"
                                            ItemsSource="{Binding DataContext.TimelineTicks, ElementName=RootWindow}"
                                            IsHitTestVisible="False">
                                <ItemsControl.Styles>
                                  <Style Selector="ItemsControl.timeline-grid-lines > ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{ReflectionBinding DataContext.Left, RelativeSource={RelativeSource Self}}"/>
                                  </Style>
                                </ItemsControl.Styles>
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <Canvas Height="40"
                                            Width="{Binding DataContext.TimelineCanvasWidth, ElementName=RootWindow}"/>
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="items:TimelineTickItemViewModel">
                                    <Border Width="1"
                                            Height="39"
                                            Background="#1E29394D"/>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>

                              <Border Width="2"
                                      Height="39"
                                      Background="#FB2C36"
                                      IsHitTestVisible="False"
                                      Canvas.Left="{Binding DataContext.TimelineCurrentLineLeft, ElementName=RootWindow}"/>

                              <ItemsControl Classes="timeline-segments"
                                            ItemsSource="{Binding Segments}">
                                <ItemsControl.Styles>
                                  <Style Selector="ItemsControl.timeline-segments > ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{ReflectionBinding DataContext.Left, RelativeSource={RelativeSource Self}}"/>
                                    <Setter Property="Canvas.Top" Value="8"/>
                                  </Style>
                                </ItemsControl.Styles>
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <Canvas Height="40"
                                            Width="{Binding DataContext.TimelineCanvasWidth, ElementName=RootWindow}"/>
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="items:TimelineEventSegmentItemViewModel">
                                    <Border Width="{Binding Width}"
                                            Height="24"
                                            Background="{Binding ColorHex}"
                                            CornerRadius="4"
                                            Opacity="0.8"
                                            IsHitTestVisible="False"/>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </Canvas>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Grid>
                </Grid>
              </ScrollViewer>
            </Grid>
          </ScrollViewer>
        </Grid>
      </Border>
    <Border Grid.RowSpan="3"
            Grid.ColumnSpan="5"
            Classes="startup-screen-overlay"
            IsVisible="{Binding IsStartupScreenVisible}">
      <Grid HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border Classes="startup-launcher"
                Width="896"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,*">
            <Border Classes="startup-header">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <StackPanel Spacing="4">
                  <TextBlock Classes="startup-title"
                             Text="Добро пожаловать в Hockey Video Analyzer"/>
                  <TextBlock Classes="startup-subtitle"
                             Text="Выберите действие для начала работы"/>
                </StackPanel>

                <Button x:Name="StartupCloseButton"
                        Grid.Column="1"
                        Classes="startup-close-button"
                        Command="{Binding CloseStartupScreenCommand}"
                        IsEnabled="{Binding CanCloseStartupScreen}"
                        Content="✕"/>
              </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="24"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="32">
              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="16">
                <Button x:Name="StartupPrimaryButton"
                        Classes="startup-action-card"
                        Command="{Binding OpenNewProjectDialogCommand}">
                  <Border Classes="startup-action-surface startup-action-surface-primary"
                          BorderBrush="#4C8DFF">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2B4666" Offset="0"/>
                        <GradientStop Color="#213650" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="33.6,17.6,17.6,17.6">
                      <Border Classes="startup-action-icon-shell"
                              Background="#30527D">
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#81C3FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="+"/>
                      </Border>

                      <StackPanel Margin="0,16,56,0"
                                  VerticalAlignment="Top"
                                  Spacing="8">
                        <TextBlock Classes="startup-action-title"
                                   Text="Новый проект"/>
                        <TextBlock Classes="startup-action-subtitle"
                                   Text="Создайте новый проект и импортируйте видео матча для анализа"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>

                <Button Grid.Column="1"
                        Classes="startup-action-card"
                        Command="{Binding OpenSelectedRecentProjectCommand}">
                  <Border Classes="startup-action-surface startup-action-surface-secondary"
                          BorderBrush="#B56BFF">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#43295A" Offset="0"/>
                        <GradientStop Color="#311E42" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="33.6,17.6,17.6,17.6">
                      <Border Classes="startup-action-icon-shell"
                              Background="#5A3680">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#E0B5FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="⤴"/>
                      </Border>

                      <StackPanel Margin="0,26,56,0"
                                  VerticalAlignment="Top"
                                  Spacing="8">
                        <TextBlock Classes="startup-action-title"
                                   Text="Открыть проект"/>
                        <TextBlock Classes="startup-action-subtitle"
                                   Text="Продолжите работу над существующим проектом"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>
              </Grid>

              <Grid Grid.Row="1"
                    RowDefinitions="Auto,Auto"
                    RowSpacing="16">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <TextBlock Classes="startup-section-title"
                             Text="НЕДАВНИЕ ПРОЕКТЫ"/>
                  <TextBlock Grid.Column="1"
                             Classes="startup-link"
                             Text="Показать все"/>
                </Grid>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding RecentProjects}"
                              IsVisible="{Binding HasRecentProjects}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal"
                                  Spacing="16"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="items:RecentProjectItemViewModel">
                      <Button Classes="startup-recent-card-button"
                              Command="{Binding #RootWindow.DataContext.OpenRecentProjectCommand}"
                              CommandParameter="{Binding}">
                        <Border Classes="recent-project-card">
                          <Grid RowDefinitions="Auto,*">
                            <Border Classes="recent-project-preview">
                              <Grid>
                                <Border Classes="recent-project-badge">
                                  <TextBlock Classes="recent-project-badge-text"
                                             Text="{Binding Matchup}"/>
                                </Border>
                              </Grid>
                            </Border>

                            <StackPanel Grid.Row="1"
                                        Margin="12"
                                        Spacing="4">
                              <TextBlock Classes="recent-project-title"
                                         Text="{Binding Name}"/>
                              <TextBlock Classes="recent-project-subtitle"
                                         MaxLines="2"
                                         Text="{Binding Summary}"/>
                              <TextBlock Classes="recent-project-meta"
                                         Margin="0,4,0,0"
                                         Text="{Binding UpdatedAtText}"/>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="1"
                        Classes="startup-empty-state"
                        IsVisible="{Binding HasNoRecentProjects}">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="recent-project-title"
                               Text="Пока нет проектов"/>
                    <TextBlock Classes="recent-project-subtitle"
                               Text="Создайте первый проект, и он появится здесь для быстрого запуска."/>
                  </StackPanel>
                </Border>
              </Grid>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border Grid.RowSpan="3"
            Grid.ColumnSpan="5"
            Classes="editor-overlay"
            Width="{Binding Bounds.Width, ElementName=RootWindow}"
            Height="{Binding Bounds.Height, ElementName=RootWindow}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsVisible="{Binding IsNewProjectDialogOpen}">
      <Grid HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border Classes="new-project-dialog"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,Auto"
                Width="860"
                MaxWidth="860">
            <Border Background="#2F2F32"
                    BorderBrush="#4C566B"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Padding="24,22">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <StackPanel Spacing="6">
                  <TextBlock Classes="dialog-title"
                             Text="Создать новый проект"/>
                  <TextBlock Classes="dialog-subtitle"
                             Text="Введите информацию о новом проекте"/>
                </StackPanel>
                <Button x:Name="NewProjectCloseButton"
                        Grid.Column="1"
                        Classes="player-control-button"
                        Command="{Binding CloseNewProjectDialogCommand}"
                        Content="X"
                        VerticalAlignment="Top"/>
              </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#2F2F32"
                    CornerRadius="0,0,12,12"
                    Padding="24">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                    RowSpacing="22">
                <StackPanel Spacing="10">
                  <TextBlock Classes="form-label"
                             Text="Название проекта *"/>
                  <Border Classes="project-form-shell single-line">
                    <Grid>
                      <TextBox Classes="project-form-plain-input single-line"
                               Text="{Binding NewProjectName}"/>
                      <TextBlock Classes="project-input-placeholder"
                                 Text="Например: СКА vs ЦСКА 15.02.2024"
                                 Foreground="#8FA3BF"
                                 Opacity="1"
                                 IsVisible="{Binding NewProjectName, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                  </Border>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Spacing="10">
                  <TextBlock Classes="form-label"
                             Text="Описание (опционально)"/>
                  <Border Classes="project-form-shell">
                    <Grid>
                      <TextBox Classes="project-form-plain-input"
                               Text="{Binding NewProjectDescription}"
                               AcceptsReturn="True"
                               TextWrapping="Wrap"
                               Height="96"/>
                      <TextBlock Classes="project-input-placeholder multiline"
                                 Text="Добавьте заметки о матче..."
                                 Foreground="#8FA3BF"
                                 Opacity="1"
                                 IsVisible="{Binding NewProjectDescription, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                  </Border>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Spacing="10">
                  <TextBlock Classes="form-label"
                             Text="Видео *"/>
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="12">
                    <Border Classes="project-form-shell single-line">
                      <Grid>
                        <TextBox Classes="project-form-plain-input single-line"
                                 Text="{Binding NewProjectVideoPath}"/>
                        <TextBlock Classes="project-input-placeholder"
                                   Text="Путь к видеофайлу"
                                   Foreground="#8FA3BF"
                                   Opacity="1"
                                   IsVisible="{Binding NewProjectVideoPath, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                      </Grid>
                    </Border>
                    <Button Grid.Column="1"
                            Classes="dialog-secondary-button"
                            Click="OnBrowseNewProjectVideoClick"
                            Content="Выбрать"/>
                  </Grid>
                </StackPanel>

                <Grid Grid.Row="3"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="22">
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="14">
                    <StackPanel Spacing="10">
                      <TextBlock Classes="form-label"
                                 Text="Команда (хозяева)"/>
                      <Border Classes="project-form-shell single-line">
                        <Grid>
                          <TextBox Classes="project-form-plain-input single-line"
                                   Text="{Binding NewProjectHomeTeam}"/>
                          <TextBlock Classes="project-input-placeholder"
                                     Text="Название команды"
                                     Foreground="#8FA3BF"
                                     Opacity="1"
                                     IsVisible="{Binding NewProjectHomeTeam, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                        </Grid>
                      </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="10">
                      <TextBlock Classes="form-label"
                                 Text="Команда (гости)"/>
                      <Border Classes="project-form-shell single-line">
                        <Grid>
                          <TextBox Classes="project-form-plain-input single-line"
                                   Text="{Binding NewProjectAwayTeam}"/>
                          <TextBlock Classes="project-input-placeholder"
                                     Text="Название команды"
                                     Foreground="#8FA3BF"
                                     Opacity="1"
                                     IsVisible="{Binding NewProjectAwayTeam, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                        </Grid>
                      </Border>
                    </StackPanel>
                  </Grid>

                  <Grid Grid.Row="1"
                        ColumnDefinitions="*,*"
                        ColumnSpacing="14">
                    <Button Grid.Column="0"
                            Classes="dialog-secondary-button"
                            Command="{Binding CloseNewProjectDialogCommand}"
                            Content="Назад"/>
                    <Button Grid.Column="1"
                            Classes="dialog-primary-button"
                            Command="{Binding ContinueNewProjectCommand}"
                            Content="Далее: Импортировать видео"/>
                  </Grid>
                </Grid>
              </Grid>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>


    <Border Grid.RowSpan="2"
            Classes="export-window-overlay"
            IsVisible="{Binding IsExportDialogOpen}">
      <Grid HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border Classes="export-window-dialog"
                Height="866"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,*,Auto">
            <Border Classes="export-window-header">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <TextBlock Classes="export-window-title"
                           VerticalAlignment="Center"
                           Text="Экспорт видео"/>
                <Button x:Name="ExportDialogCloseButton"
                        Grid.Column="1"
                        Classes="startup-close-button"
                        Command="{Binding CloseExportDialogCommand}"
                        IsEnabled="{Binding CanCloseExportDialog}"
                        Content="×"/>
              </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="24"
                          Spacing="24">
                <StackPanel Spacing="12">
                  <TextBlock Classes="export-window-label"
                             Text="Что экспортировать"/>
                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="8">
                    <ToggleButton Grid.Column="0"
                                  Classes="export-option-button large"
                                  IsChecked="{Binding IsExportAllClipsSelected}"
                                  Command="{Binding SelectExportSourceCommand}"
                                  CommandParameter="AllClips">
                      <StackPanel Spacing="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                        <Path Data="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z M14.5 2v5.5H20.5"
                              Stroke="{Binding $parent[ToggleButton].Foreground}"
                              StrokeThickness="1.67"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="20"
                              Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"/>
                        <TextBlock FontSize="12"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Center"
                                   Text="Все клипы"/>
                      </StackPanel>
                    </ToggleButton>
                    <ToggleButton Grid.Column="1"
                                  Classes="export-option-button large"
                                  IsChecked="{Binding IsExportPlaylistSelected}"
                                  Command="{Binding SelectExportSourceCommand}"
                                  CommandParameter="Playlist">
                      <StackPanel Spacing="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                        <Path Data="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z M14.5 2v5.5H20.5"
                              Stroke="{Binding $parent[ToggleButton].Foreground}"
                              StrokeThickness="1.67"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="20"
                              Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"/>
                        <TextBlock FontSize="12"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Center"
                                   Text="Плейлист"/>
                      </StackPanel>
                    </ToggleButton>
                    <ToggleButton Grid.Column="2"
                                  Classes="export-option-button large"
                                  IsChecked="{Binding IsExportFullMatchSelected}"
                                  Command="{Binding SelectExportSourceCommand}"
                                  CommandParameter="FullMatch">
                      <StackPanel Spacing="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                        <Path Data="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z M14.5 2v5.5H20.5"
                              Stroke="{Binding $parent[ToggleButton].Foreground}"
                              StrokeThickness="1.67"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="20"
                              Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"/>
                        <TextBlock FontSize="12"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Center"
                                   Text="Полный матч"/>
                      </StackPanel>
                    </ToggleButton>
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="12">
                  <TextBlock Classes="export-window-label"
                             Text="Формат"/>
                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="8">
                    <ToggleButton Grid.Column="0"
                                  Classes="export-option-button medium"
                                  IsChecked="{Binding IsExportFormatMp4Selected}"
                                  Command="{Binding SelectExportFormatCommand}"
                                  CommandParameter="Mp4"
                                  Content=".MP4"/>
                    <ToggleButton Grid.Column="1"
                                  Classes="export-option-button medium"
                                  IsChecked="{Binding IsExportFormatAviSelected}"
                                  Command="{Binding SelectExportFormatCommand}"
                                  CommandParameter="Avi"
                                  Content=".AVI"/>
                    <ToggleButton Grid.Column="2"
                                  Classes="export-option-button medium"
                                  IsChecked="{Binding IsExportFormatMovSelected}"
                                  Command="{Binding SelectExportFormatCommand}"
                                  CommandParameter="Mov"
                                  Content=".MOV"/>
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="12">
                  <TextBlock Classes="export-window-label"
                             Text="Качество"/>
                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="8">
                    <ToggleButton Grid.Column="0"
                                  Classes="export-option-button small"
                                  IsChecked="{Binding IsExportQualityLowSelected}"
                                  Command="{Binding SelectExportQualityCommand}"
                                  CommandParameter="Low720p"
                                  Content="Низкое (720p)"/>
                    <ToggleButton Grid.Column="1"
                                  Classes="export-option-button small"
                                  IsChecked="{Binding IsExportQualityMediumSelected}"
                                  Command="{Binding SelectExportQualityCommand}"
                                  CommandParameter="Medium1080p"
                                  Content="Среднее (1080p)"/>
                    <ToggleButton Grid.Column="2"
                                  Classes="export-option-button small"
                                  IsChecked="{Binding IsExportQualityHighSelected}"
                                  Command="{Binding SelectExportQualityCommand}"
                                  CommandParameter="High4K"
                                  Content="Высокое (4K)"/>
                  </Grid>
                </StackPanel>

                <ToggleButton Classes="export-checkbox-row"
                              IsChecked="{Binding ExportIncludeTacticalDrawings, Mode=TwoWay}">
                  <Grid ColumnDefinitions="16,*"
                        ColumnSpacing="12"
                        VerticalAlignment="Center">
                    <Border Width="16"
                            Height="16"
                            CornerRadius="4"
                            BorderBrush="#64748B"
                            BorderThickness="1"
                            Background="#1A1A1A">
                      <TextBlock HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 FontSize="12"
                                 Foreground="#FFFFFF"
                                 Text="✓"
                                 IsVisible="{Binding #RootWindow.DataContext.ExportIncludeTacticalDrawings}"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Medium"
                               Text="Включить тактические рисунки"/>
                  </Grid>
                </ToggleButton>

                <StackPanel Spacing="12">
                  <TextBlock Classes="export-window-label"
                             Text="Куда сохранить"/>
                  <StackPanel Spacing="8">
                    <ToggleButton Classes="export-option-button full"
                                  IsChecked="{Binding IsExportDestinationFolderSelected}"
                                  Command="{Binding SelectExportDestinationCommand}"
                                  CommandParameter="Folder">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="12"
                                  VerticalAlignment="Center">
                        <Path Data="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"
                              Stroke="{Binding $parent[ToggleButton].Foreground}"
                              StrokeThickness="1.33"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Text="Сохранить в папку"/>
                      </StackPanel>
                    </ToggleButton>
                    <ToggleButton Classes="export-option-button full"
                                  IsChecked="{Binding IsExportDestinationTelegramSelected}"
                                  Command="{Binding SelectExportDestinationCommand}"
                                  CommandParameter="Telegram">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="12"
                                  VerticalAlignment="Center">
                        <Path Data="M22 2L11 13 M22 2l-7 20-4-9-9-4 20-7z"
                              Stroke="{Binding $parent[ToggleButton].Foreground}"
                              StrokeThickness="1.33"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Text="Отправить в Telegram"/>
                      </StackPanel>
                    </ToggleButton>
                    <ToggleButton Classes="export-option-button full"
                                  IsChecked="{Binding IsExportDestinationBothSelected}"
                                  Command="{Binding SelectExportDestinationCommand}"
                                  CommandParameter="Both">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="12"
                                  VerticalAlignment="Center">
                        <Path Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M17 8l-5-5-5 5 M12 3v12"
                              Stroke="{Binding $parent[ToggleButton].Foreground}"
                              StrokeThickness="1.33"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Text="Оба варианта"/>
                      </StackPanel>
                    </ToggleButton>
                  </StackPanel>
                </StackPanel>

                <StackPanel Spacing="8">
                  <TextBlock Classes="export-window-label"
                             Text="Путь к папке"/>
                  <Border Classes="export-path-shell">
                    <TextBox Classes="export-path-input"
                             Text="{Binding ExportFolderPath}"/>
                  </Border>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    BorderBrush="#364153"
                    BorderThickness="0,1,0,0"
                    Padding="16">
              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="12">
                <Button Grid.Column="0"
                        Classes="export-footer-secondary"
                        Command="{Binding CloseExportDialogCommand}"
                        IsEnabled="{Binding CanCloseExportDialog}"
                        Content="Отмена"/>
                <Button Grid.Column="1"
                        Classes="export-footer-primary"
                        Command="{Binding ExportFromDialogCommand}"
                        IsEnabled="{Binding CanExportFromDialog}">
                  <StackPanel Orientation="Horizontal"
                              HorizontalAlignment="Center"
                              Spacing="8">
                    <Path Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M17 8l-5-5-5 5 M12 3v12"
                          Stroke="White"
                          StrokeThickness="1.33"
                          StrokeLineCap="Round"
                          StrokeJoin="Round"
                          Fill="Transparent"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"
                          VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ExportPrimaryButtonText}"/>
                  </StackPanel>
                </Button>
              </Grid>
            </Border>

            <Border Grid.RowSpan="3"
                    Background="#B8141720"
                    IsVisible="{Binding IsExportInProgress}">
              <Border Width="360"
                      Padding="24"
                      CornerRadius="20"
                      BorderBrush="#364153"
                      BorderThickness="1"
                      Background="#1A1D24"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                <StackPanel Spacing="16">
                  <TextBlock HorizontalAlignment="Center"
                             FontSize="24"
                             FontWeight="SemiBold"
                             Foreground="#F8FAFC"
                             Text="Рендерим видео"/>
                  <TextBlock Text="{Binding ExportProgressText}"
                             FontSize="14"
                             Foreground="#CBD5E1"
                             TextAlignment="Center"/>
                  <ProgressBar MinWidth="260"
                               Height="10"
                               IsIndeterminate="True"
                               Foreground="#155DFC"
                               Background="#0F172A"/>
                </StackPanel>
              </Border>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
  </Grid>
</Window>



















