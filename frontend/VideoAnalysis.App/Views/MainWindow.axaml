<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VideoAnalysis.App.ViewModels.Shell"
        xmlns:models="using:VideoAnalysis.Core.Models"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        x:Class="VideoAnalysis.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1600"
        Height="960"
        MinWidth="1180"
        MinHeight="760"
        Title="Video Analytics - Hockey MVP"
        Background="#0B1220"
        Foreground="#E5EDF9"
        ClipToBounds="True">

  <Window.Styles>
    <Style Selector="Border.top-menu-bar">
      <Setter Property="Background" Value="#1D1D20"/>
      <Setter Property="Padding" Value="8,4"/>
    </Style>

    <Style Selector="Button.top-menu-item">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="14,6,14,10"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="14,6,14,10"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.top-menu-item /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.top-menu-item:pointerover">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:pointerover">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="Button.top-menu-item:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.top-menu-item:pressed">
      <Setter Property="Background" Value="#45454A"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:checked">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="Button.top-menu-item:pressed /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:checked /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Border.file-menu-popup">
      <Setter Property="Background" Value="#232327"/>
      <Setter Property="BorderBrush" Value="#3A3A3E"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="6"/>
      <Setter Property="BoxShadow" Value="0 8 24 0 #66000000"/>
    </Style>

    <Style Selector="Button.file-menu-item">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="MinWidth" Value="220"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.file-menu-item /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.file-menu-item:pointerover">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="Button.file-menu-item:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.player-button">
      <Setter Property="Background" Value="#24324A"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="Button.player-button:pointerover">
      <Setter Property="Background" Value="#304563"/>
    </Style>

    <Style Selector="Button.player-control-button, ToggleButton.player-control-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.player-control-button:pointerover, ToggleButton.player-control-button:pointerover">
      <Setter Property="Background" Value="#263246"/>
    </Style>

    <Style Selector="Button.player-control-button:pressed, ToggleButton.player-control-button:checked">
      <Setter Property="Background" Value="#304563"/>
    </Style>

    <Style Selector="Border.player-control-bar">
      <Setter Property="Background" Value="#1D1D20"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="10,6,10,14"/>
      <Setter Property="BorderBrush" Value="#2A3A55"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="Border.player-seek-surface">
      <Setter Property="Height" Value="28"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.player-seek-track">
      <Setter Property="Height" Value="4"/>
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Background" Value="#31435E"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.player-seek-progress">
      <Setter Property="Height" Value="4"/>
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Background" Value="#2F86FF"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Width" Value="0"/>
    </Style>

    <Style Selector="TextBox.player-input">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="CaretBrush" Value="#F7FAFF"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
    </Style>

    <Style Selector="TextBox.player-input:pointerover">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#3A567C"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.player-input:focus">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2F86FF"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.player-input /template/ Border">
      <Setter Property="Background" Value="#162238"/>
    </Style>

    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#111A2B"/>
      <Setter Property="BorderBrush" Value="#24324A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBlock.section-subtitle">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="Border.placeholder-card">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="TextBox.event-type-input">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="CaretBrush" Value="#F7FAFF"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#3A567C"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2F86FF"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ Border">
      <Setter Property="Background" Value="#162238"/>
    </Style>

    <Style Selector="Button.action-button">
      <Setter Property="Background" Value="#203867"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="Button.action-button:pointerover">
      <Setter Property="Background" Value="#2A4A86"/>
    </Style>

    <Style Selector="ListBox.event-type-list">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="ListBox.event-type-list ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*" ClipToBounds="True">
    <Border Grid.Row="0" Classes="top-menu-bar">
      <Grid ColumnDefinitions="Auto,*">
        <StackPanel Orientation="Horizontal" Spacing="2">
          <ToggleButton x:Name="FileMenuButton"
                        Classes="top-menu-item"
                        Checked="OnFileMenuChecked"
                        Content="Файл"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=FileMenuButton}"
                 PlacementTarget="{Binding #FileMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item" Content="Новый проект" Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Открыть..." Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Сохранить" Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Сохранить как..." Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Экспорт" Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Выход" Click="OnFileMenuActionClick"/>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
          <Button Classes="top-menu-item" Content="Формат"/>
          <ToggleButton x:Name="ViewMenuButton"
                        Classes="top-menu-item"
                        Checked="OnViewMenuChecked"
                        Content="Вид"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=ViewMenuButton}"
                 PlacementTarget="{Binding #ViewMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item" Content="Показывать статистику" Click="OnViewMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Показывать анализ" Click="OnViewMenuActionClick"/>
              </StackPanel>
            </Border>
          </Popup>
          <ToggleButton x:Name="HelpMenuButton"
                        Classes="top-menu-item"
                        Checked="OnHelpMenuChecked"
                        Content="Помощь"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=HelpMenuButton}"
                 PlacementTarget="{Binding #HelpMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item" Content="Документация" Click="OnHelpMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Горячие клавиши" Click="OnHelpMenuActionClick"/>
                <Button Classes="file-menu-item" Content="О программе" Click="OnHelpMenuActionClick"/>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="12" ClipToBounds="True">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="3.2*" MinWidth="420"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="1.05*" MinWidth="250"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="1.45*" MinWidth="280"/>
      </Grid.ColumnDefinitions>

      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="260"/>
        <RowDefinition Height="6"/>
        <RowDefinition Height="240" MinHeight="170"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Grid.Column="0" Classes="panel">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14" ClipToBounds="True">
          <StackPanel Spacing="4">
            <TextBlock Classes="section-title" Text="Плеер"/>
            <TextBlock Classes="section-subtitle" Text="{Binding StatusMessage}"/>
          </StackPanel>

          <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <TextBox Grid.Column="0"
                     Classes="player-input"
                     Watermark="C:\video.mp4"
                     Text="{Binding SourceVideoPath}"/>
            <Button Grid.Column="1"
                    Classes="player-button"
                    Command="{Binding ImportFromPathCommand}"
                    Content="Открыть"/>
          </Grid>

          <Border Grid.Row="2"
                  Background="#050B14"
                  BorderBrush="#2A3A55"
                  BorderThickness="1"
                  CornerRadius="10"
                  ClipToBounds="True">
            <vlc:VideoView x:Name="PlayerView"
                           MediaPlayer="{Binding MediaPlayer}"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"/>
          </Border>

          <Border Grid.Row="3" Classes="player-control-bar">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                  ColumnSpacing="10"
                  VerticalAlignment="Center">
              <Button Grid.Column="0"
                      Classes="player-control-button"
                      Command="{Binding TogglePlayPauseCommand}">
                <TextBlock Text="{Binding PlaybackGlyph}" FontFamily="Segoe UI Symbol" FontSize="20"/>
              </Button>

              <Border Grid.Column="1"
                      Classes="player-seek-surface"
                      PointerPressed="OnSeekBarPointerPressed"
                      PointerMoved="OnSeekBarPointerMoved"
                      PointerReleased="OnSeekBarPointerReleased">
                <Grid x:Name="SeekBarRoot"
                      Height="18"
                      VerticalAlignment="Center"
                      SizeChanged="OnSeekBarSizeChanged">
                  <Border Classes="player-seek-track"/>
                  <Border x:Name="SeekBarProgress" Classes="player-seek-progress"/>
                  <Ellipse x:Name="SeekBarThumb"
                           Width="18"
                           Height="18"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Fill="#2F86FF"/>
                </Grid>
              </Border>

              <TextBlock Grid.Column="2"
                         VerticalAlignment="Center"
                         Foreground="#D9E5F8"
                         FontSize="14"
                         FontWeight="SemiBold">
                <Run Text="{Binding CurrentTimeText}"/>
                <Run Text=" / "/>
                <Run Text="{Binding DurationTimeText}"/>
              </TextBlock>

              <ToggleButton x:Name="VolumeButton"
                            Grid.Column="3"
                            Classes="player-control-button">
                <TextBlock Text="{Binding VolumeGlyph}" FontFamily="Segoe UI Symbol" FontSize="18"/>
              </ToggleButton>
              <Popup IsOpen="{Binding IsChecked, ElementName=VolumeButton}"
                     PlacementTarget="{Binding #VolumeButton}"
                     Placement="Top"
                     HorizontalOffset="-36"
                     VerticalOffset="-8">
                <Border Classes="file-menu-popup" Padding="12">
                  <StackPanel Spacing="10">
                    <Button Classes="player-control-button"
                            HorizontalAlignment="Center"
                            Command="{Binding ToggleMuteCommand}">
                      <TextBlock Text="{Binding VolumeGlyph}" FontFamily="Segoe UI Symbol" FontSize="18"/>
                    </Button>
                    <Slider Width="100"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding Volume, Mode=TwoWay}"/>
                  </StackPanel>
                </Border>
              </Popup>

              <Button Grid.Column="4"
                      Classes="player-control-button"
                      Click="OnToggleFullscreenClick">
                <TextBlock Text="⛶" FontFamily="Segoe UI Symbol" FontSize="18"/>
              </Button>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <GridSplitter Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="1"
                    Width="6"
                    Background="#24324A"
                    ResizeDirection="Columns"
                    HorizontalAlignment="Stretch"/>

      <Border Grid.Row="0"
              Grid.RowSpan="3"
              Grid.Column="2"
              Classes="panel">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      ClipToBounds="True">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14" ClipToBounds="True">
            <StackPanel Spacing="4">
              <TextBlock Classes="section-title" Text="Типы событий"/>
              <TextBlock Classes="section-subtitle" Text="Список типов событий проекта и форма для создания и редактирования"/>
            </StackPanel>

            <Border Grid.Row="1" Classes="placeholder-card">
              <StackPanel Spacing="10">
                <TextBlock Text="Типы событий"
                           FontSize="16"
                           FontWeight="SemiBold"/>
                <ListBox Classes="event-type-list"
                         ItemsSource="{Binding TagPresets}"
                         SelectedItem="{Binding SelectedPreset, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:TagPreset">
                      <Border Background="{Binding ColorHex}"
                              CornerRadius="8"
                              Padding="12,10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                          <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       Foreground="#F7FAFF"/>
                            <TextBlock Text="{Binding Category}"
                                       Foreground="#DCE6F5"
                                       FontSize="12"/>
                          </StackPanel>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Hotkey}"
                                     VerticalAlignment="Center"
                                     Foreground="#F7FAFF"
                                     FontWeight="SemiBold"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>

            <Border Grid.Row="2" Classes="placeholder-card">
              <StackPanel Spacing="10">
                <TextBlock Text="Редактирование"
                           FontSize="16"
                           FontWeight="SemiBold"/>
                <TextBox Classes="event-type-input"
                         Watermark="Название"
                         Text="{Binding EventTypeName}"/>
                <TextBox Classes="event-type-input"
                         Watermark="Hotkey"
                         Text="{Binding EventTypeHotkey}"/>
                <TextBox Classes="event-type-input"
                         Watermark="#RRGGBB"
                         Text="{Binding EventTypeColor}"/>
                <TextBox Classes="event-type-input"
                         Watermark="Категория"
                         Text="{Binding EventTypeCategory}"/>
                <TextBox Classes="event-type-input"
                         Watermark="Icon key"
                         Text="{Binding EventTypeIconKey}"/>
              </StackPanel>
            </Border>

            <Grid Grid.Row="3" ColumnDefinitions="*,*,*" ColumnSpacing="10">
              <Button Grid.Column="0"
                      Classes="action-button"
                      Command="{Binding AddPresetCommand}"
                      Content="Создать"/>
              <Button Grid.Column="1"
                      Classes="action-button"
                      Command="{Binding SavePresetCommand}"
                      Content="Сохранить"/>
              <Button Grid.Column="2"
                      Classes="action-button"
                      Command="{Binding DeletePresetCommand}"
                      IsEnabled="{Binding CanDeleteSelectedPreset}"
                      Content="Удалить"/>
            </Grid>
          </Grid>
        </ScrollViewer>
      </Border>

      <GridSplitter Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="3"
                    Width="6"
                    Background="#24324A"
                    ResizeDirection="Columns"
                    HorizontalAlignment="Stretch"/>

      <Border Grid.Row="0"
              Grid.RowSpan="3"
              Grid.Column="4"
              Classes="panel">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      ClipToBounds="True">
          <Grid RowDefinitions="Auto,Auto,*,*" RowSpacing="14" ClipToBounds="True">
            <StackPanel Spacing="4">
              <TextBlock Classes="section-title" Text="Статистика проекта"/>
              <TextBlock Classes="section-subtitle" Text="Крайняя правая панель для сводки, графиков и чисел"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Classes="placeholder-card"
                    Padding="12,8">
              <TextBlock Text="Панель пока оформлена как каркас без привязки к данным"
                         TextWrapping="Wrap"
                         Foreground="#AAB9CF"/>
            </Border>

            <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12">
              <Border Grid.Column="0" Classes="placeholder-card">
                <StackPanel Spacing="8">
                  <TextBlock Text="Ключевые показатели"
                             FontSize="16"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap"/>
                  <TextBlock Text="Счётчики, KPI, агрегаты"
                             Foreground="#AAB9CF"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="placeholder-card">
                <StackPanel Spacing="8">
                  <TextBlock Text="Сводка по матчу"
                             FontSize="16"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap"/>
                  <TextBlock Text="Счёт, периоды, сравнение команд"
                             Foreground="#AAB9CF"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
            </Grid>

            <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="12">
              <Border Grid.Column="0" Classes="placeholder-card">
                <StackPanel Spacing="8">
                  <TextBlock Text="Диаграммы"
                             FontSize="16"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap"/>
                  <TextBlock Text="Проценты, кольцевые индикаторы, тренды"
                             Foreground="#AAB9CF"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="placeholder-card">
                <StackPanel Spacing="8">
                  <TextBlock Text="Дополнительная аналитика"
                             FontSize="16"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap"/>
                  <TextBlock Text="Игроки, типы событий, временные срезы"
                             Foreground="#AAB9CF"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
            </Grid>
          </Grid>
        </ScrollViewer>
      </Border>

      <GridSplitter Grid.Row="1"
                    Grid.Column="0"
                    Height="6"
                    Background="#24324A"
                    ResizeDirection="Rows"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>

      <Border Grid.Row="2" Grid.Column="0" Classes="panel">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      ClipToBounds="True">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14" ClipToBounds="True">
            <StackPanel Spacing="4">
              <TextBlock Classes="section-title" Text="Таймлайн"/>
              <TextBlock Classes="section-subtitle" Text="Нижняя левая зона для шкалы времени, маркеров и навигации"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Classes="placeholder-card"
                    Padding="12,8">
              <TextBlock Text="Будущий таймлайн будет размещён здесь"
                         Foreground="#AAB9CF"
                         TextWrapping="Wrap"/>
            </Border>

            <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="12">
              <Grid ColumnDefinitions="90,*" ColumnSpacing="12">
                <TextBlock Text="Время"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#D8E4F7"/>
                <Border Grid.Column="1"
                        Height="18"
                        CornerRadius="9"
                        Background="#162238"
                        BorderBrush="#2B3C59"
                        BorderThickness="1"/>
              </Grid>

              <Grid Grid.Row="1" ColumnDefinitions="120,*" ColumnSpacing="12">
                <StackPanel Spacing="10">
                  <Border Classes="placeholder-card" Padding="10">
                    <TextBlock Text="Слои событий" TextWrapping="Wrap"/>
                  </Border>
                  <Border Classes="placeholder-card" Padding="10">
                    <TextBlock Text="Фильтры" TextWrapping="Wrap"/>
                  </Border>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#0A101C"
                        BorderBrush="#2A3A55"
                        BorderThickness="1"
                        CornerRadius="8"
                        ClipToBounds="True">
                  <Grid Margin="14" ClipToBounds="True">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="*"/>
                      <RowDefinition Height="*"/>
                      <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="1" Margin="2" Background="#1A2640" CornerRadius="4"/>
                    <Border Grid.Row="0" Grid.Column="4" Margin="2" Background="#1A2640" CornerRadius="4"/>
                    <Border Grid.Row="1" Grid.Column="2" Margin="2" Background="#203867" CornerRadius="4"/>
                    <Border Grid.Row="1" Grid.Column="5" Margin="2" Background="#203867" CornerRadius="4"/>
                    <Border Grid.Row="2" Grid.Column="3" Margin="2" Background="#694D11" CornerRadius="4"/>
                  </Grid>
                </Border>
              </Grid>
            </Grid>
          </Grid>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</Window>
