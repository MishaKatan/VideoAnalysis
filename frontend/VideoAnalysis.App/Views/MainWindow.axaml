      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Button.startup-recent-card-button:pointerover Border.recent-project-card">
      <Setter Property="BorderBrush" Value="#4A70C7"/>
      <Setter Property="Background" Value="#232C3A"/>
    </Style>

    <Style Selector="Border.recent-project-preview">
      <Setter Property="Height" Value="151.8"/>
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#253549" Offset="0"/>
          <GradientStop Color="#1E2939" Offset="1"/>
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Border.recent-project-badge">
      <Setter Property="Background" Value="#00000080"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="VerticalAlignment" Value="Bottom"/>
      <Setter Property="Margin" Value="8,0,8,8"/>
    </Style>

    <Style Selector="TextBlock.recent-project-badge-text">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#E5EDF9"/>
      <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <Style Selector="TextBlock.recent-project-title">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="#F5F7FB"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="MaxLines" Value="2"/>
    </Style>

    <Style Selector="TextBlock.recent-project-subtitle">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#99A1AF"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="MaxLines" Value="2"/>
    </Style>

    <Style Selector="TextBlock.recent-project-meta">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="#7E8A9A"/>
      <Setter Property="TextWrapping" Value="NoWrap"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style Selector="Border.startup-empty-state">
      <Setter Property="Background" Value="#1A1A1A"/>
      <Setter Property="BorderBrush" Value="#364153"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="24"/>
      <Setter Property="MinHeight" Value="160"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*" ClipToBounds="True">
    <Border Grid.Row="0" Classes="top-menu-bar">
      <Grid ColumnDefinitions="Auto,*">
        <StackPanel Orientation="Horizontal" Spacing="2">
          <ToggleButton x:Name="FileMenuButton"
                        Classes="top-menu-item"
                        Checked="OnFileMenuChecked"
                        Content="Файл"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=FileMenuButton}"
                 PlacementTarget="{Binding #FileMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item" Content="Новый проект" Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Открыть..." Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Сохранить" Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Сохранить как..." Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Экспорт" Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Выход" Click="OnFileMenuActionClick"/>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
          <Button Classes="top-menu-item" Content="Формат"/>
          <ToggleButton x:Name="ViewMenuButton"
                        Classes="top-menu-item"
                        Checked="OnViewMenuChecked"
                        Content="Вид"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=ViewMenuButton}"
                 PlacementTarget="{Binding #ViewMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item" Content="Показывать статистику" Click="OnViewMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Показывать анализ" Click="OnViewMenuActionClick"/>
              </StackPanel>
            </Border>
          </Popup>
          <ToggleButton x:Name="HelpMenuButton"
                        Classes="top-menu-item"
                        Checked="OnHelpMenuChecked"
                        Content="Помощь"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=HelpMenuButton}"
                 PlacementTarget="{Binding #HelpMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item" Content="Документация" Click="OnHelpMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Горячие клавиши" Click="OnHelpMenuActionClick"/>
                <Button Classes="file-menu-item" Content="О программе" Click="OnHelpMenuActionClick"/>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="12" ClipToBounds="True">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="3.2*" MinWidth="420"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="1.05*" MinWidth="250"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="1.45*" MinWidth="280"/>
      </Grid.ColumnDefinitions>

      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="260"/>
        <RowDefinition Height="6"/>
        <RowDefinition Height="240" MinHeight="170"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Grid.Column="0" Classes="panel">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="14" ClipToBounds="True">
          <StackPanel Spacing="4">
            <TextBlock Classes="section-title" Text="Плеер"/>
            <TextBlock Classes="section-subtitle" Text="{Binding StatusMessage}"/>
          </StackPanel>

          <Border x:Name="PlayerSurfaceHost"
                  Grid.Row="1"
                  Background="#050B14"
                  BorderBrush="#2A3A55"
                  BorderThickness="1"
                  CornerRadius="10"
                  ClipToBounds="True"
                  IsVisible="{Binding IsPlayerSurfaceVisible}">
            <vlc:VideoView x:Name="PlayerView"
                           MediaPlayer="{Binding MediaPlayer}"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"/>
          </Border>

          <Border Grid.Row="2" Classes="player-control-bar">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                  ColumnSpacing="10"
                  VerticalAlignment="Center">
              <Button Grid.Column="0"
                      Classes="player-control-button"
                      Command="{Binding TogglePlayPauseCommand}">
                <TextBlock Text="{Binding PlaybackGlyph}" FontFamily="Segoe UI Symbol" FontSize="20"/>
              </Button>

              <Border Grid.Column="1"
                      Classes="player-seek-surface"
                      PointerPressed="OnSeekBarPointerPressed"
                      PointerMoved="OnSeekBarPointerMoved"
                      PointerReleased="OnSeekBarPointerReleased">
                <Grid x:Name="SeekBarRoot"
                      Height="18"
                      VerticalAlignment="Center"
                      SizeChanged="OnSeekBarSizeChanged">
                  <Border Classes="player-seek-track"/>
                  <Border x:Name="SeekBarProgress" Classes="player-seek-progress"/>
                  <Ellipse x:Name="SeekBarThumb"
                           Width="18"
                           Height="18"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Fill="#2F86FF"/>
                </Grid>
              </Border>

              <TextBlock Grid.Column="2"
                         VerticalAlignment="Center"
                         Foreground="#D9E5F8"
                         FontSize="14"
                         FontWeight="SemiBold">
                <Run Text="{Binding CurrentTimeText}"/>
                <Run Text=" / "/>
                <Run Text="{Binding DurationTimeText}"/>
              </TextBlock>

              <ToggleButton x:Name="VolumeButton"
                            Grid.Column="3"
                            Classes="player-control-button">
                <TextBlock Text="{Binding VolumeGlyph}" FontFamily="Segoe UI Symbol" FontSize="18"/>
              </ToggleButton>
              <Popup IsOpen="{Binding IsChecked, ElementName=VolumeButton}"
                     PlacementTarget="{Binding #VolumeButton}"
                     Placement="Top"
                     HorizontalOffset="-36"
                     VerticalOffset="-8">
                <Border Classes="file-menu-popup" Padding="12">
                  <StackPanel Spacing="10">
                    <Button Classes="player-control-button"
                            HorizontalAlignment="Center"
                            Command="{Binding ToggleMuteCommand}">
                      <TextBlock Text="{Binding VolumeGlyph}" FontFamily="Segoe UI Symbol" FontSize="18"/>
                    </Button>
                    <Slider Width="100"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding Volume, Mode=TwoWay}"/>
                  </StackPanel>
                </Border>
              </Popup>

              <Button Grid.Column="4"
                      Classes="player-control-button"
                      Click="OnToggleFullscreenClick">
                <TextBlock Text="⛶" FontFamily="Segoe UI Symbol" FontSize="18"/>
              </Button>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <GridSplitter Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="1"
                    Width="6"
                    Background="#24324A"
                    ResizeDirection="Columns"
                    HorizontalAlignment="Stretch"/>

      <Border Grid.Row="0"
              Grid.RowSpan="3"
              Grid.Column="2"
              Classes="panel"
              Padding="0">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      ClipToBounds="True">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14" ClipToBounds="True">
            <Border Grid.Row="0" Classes="panel-tabs">
              <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
                <ToggleButton Grid.Column="0"
                              Classes="tab-button"
                              IsChecked="{Binding IsEventTypesTabSelected}"
                              Command="{Binding SelectEventsPanelTabCommand}"
                              CommandParameter="EventTypes"
                              Content="Типы событий"/>
                <ToggleButton Grid.Column="1"
                              Classes="tab-button"
                              IsChecked="{Binding IsEventsTabSelected}"
                              Command="{Binding SelectEventsPanelTabCommand}"
                              CommandParameter="Events"
                              Content="События"/>
              </Grid>
            </Border>
            <Grid Grid.Row="1"
                  Grid.RowSpan="3"
                  Margin="18,0,18,18"
                  RowDefinitions="Auto,*,Auto"
                  RowSpacing="10"
                  IsVisible="{Binding IsEventsTabSelected}">
                <TextBlock Text="События"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <ListBox Grid.Row="1"
                         Classes="event-type-list"
                         ItemsSource="{Binding TagEvents}"
                         SelectedItem="{Binding SelectedTagEvent, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#1A2640"
                              CornerRadius="8"
                              Padding="12,10"
                              DoubleTapped="OnTagEventItemDoubleTapped">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <TextBlock Text="{Binding PresetName}"
                                       FontWeight="SemiBold"
                                      Foreground="#F7FAFF"/>
                            <StackPanel Grid.Column="1"
                                        Spacing="2"
                                        HorizontalAlignment="Right">
                              <TextBlock Text="{Binding TeamSide}"
                                         Foreground="#9EB5D4"
                                         FontWeight="SemiBold"
                                         HorizontalAlignment="Right"/>
                              <Button Classes="event-eye-button"
                                      HorizontalAlignment="Right"
                                      Click="OnTagEventPreviewClick">
                                <TextBlock Text="👁" FontSize="12"/>
                              </Button>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Classes="event-eye-button"
                                    Command="{Binding #RootWindow.DataContext.TogglePlaylistSelectionCommand}"
                                    CommandParameter="{Binding}"
                                    VerticalAlignment="Top">
                              <TextBlock Text="{Binding PlaylistToggleGlyph}"
                                         FontSize="16"
                                         FontWeight="SemiBold"/>
                            </Button>
                          </Grid>
                          <TextBlock Grid.Row="1"
                                     Foreground="#C9D7EB"
                                     Text="{Binding StartFrame, StringFormat='Старт: {0}'}"/>
                          <TextBlock Grid.Row="2"
                                     Foreground="#C9D7EB"
                                     Text="{Binding EndFrame, StringFormat='Конец: {0}'}"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="2" ColumnDefinitions="*" ColumnSpacing="10">
                  <Button Grid.Column="0"
                          Classes="action-button"
                          Command="{Binding OpenNewTagEventEditorCommand}"
                          Content="Новое событие"/>
                </Grid>
            </Grid>
            <Grid Grid.Row="1"
                  Margin="18,0,18,0"
                  IsVisible="{Binding IsEventTypesTabSelected}">
              <StackPanel Spacing="10">
                <TextBlock Text="Типы событий"
                           FontSize="16"
                           FontWeight="SemiBold"/>
                <ListBox Classes="event-type-list"
                         ItemsSource="{Binding TagPresets}"
                         SelectedItem="{Binding SelectedPreset, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:TagPreset">
                      <Border Background="{Binding ColorHex}"
                              CornerRadius="8"
                              Padding="12,10"
                              DoubleTapped="OnEventTypeItemDoubleTapped">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                          <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       Foreground="#F7FAFF"/>
                            <TextBlock Text="{Binding Category}"
                                       Foreground="#DCE6F5"
                                       FontSize="12"/>
                          </StackPanel>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Hotkey}"
                                     VerticalAlignment="Center"
                                     Foreground="#F7FAFF"
                                     FontWeight="SemiBold"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Grid>

            <Border Grid.Row="2" Classes="placeholder-card" Margin="18,0,18,0" IsVisible="False">
              <StackPanel Spacing="10">
                <TextBlock Text="Редактирование"
                           FontSize="16"
                           FontWeight="SemiBold"/>
                <TextBox Classes="event-type-input"
                         Watermark="Название"
                         Text="{Binding EventTypeName}"/>
                <TextBox Classes="event-type-input"
                         Watermark="Hotkey"
                         Text="{Binding EventTypeHotkey}"/>
                <TextBox Classes="event-type-input"
                         Watermark="#RRGGBB"
                         Text="{Binding EventTypeColor}"/>
                <TextBox Classes="event-type-input"
                         Watermark="Категория"
                         Text="{Binding EventTypeCategory}"/>
                <TextBox Classes="event-type-input"
                         Watermark="Icon key"
                         Text="{Binding EventTypeIconKey}"/>
              </StackPanel>
            </Border>

            <Grid Grid.Row="3"
                  ColumnDefinitions="*"
                  ColumnSpacing="10"
                  Margin="18,0,18,18"
                  IsVisible="{Binding IsEventTypesTabSelected}">
              <Button Grid.Column="0"
                      Classes="action-button"
                      Command="{Binding OpenNewPresetEditorCommand}"
                      Content="Новый тип событий"/>
            </Grid>

            <Border Grid.Row="0"
                    Grid.RowSpan="4"
                    Classes="editor-overlay"
                    IsVisible="{Binding IsPresetEditorOpen}">
              <Grid HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Border Classes="editor-dialog"
                        x:Name="PresetEditorDialog"
                        Focusable="True"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">
                  <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                      <TextBlock Text="{Binding PresetEditorTitle}"
                                 FontSize="18"
                                 FontWeight="SemiBold"
                                 Foreground="#F7FAFF"/>
                      <Button x:Name="PresetEditorCloseButton"
                              Grid.Column="1"
                              Classes="player-control-button"
                              Command="{Binding ClosePresetEditorCommand}"
                              Content="X"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Spacing="10">
                      <Grid>
                        <TextBox Classes="event-type-input"
                                 Text="{Binding EventTypeName}"/>
                        <TextBlock Classes="input-placeholder"
                                   Text="Название"
                                   IsVisible="{Binding EventTypeName, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                      </Grid>
                      <Grid>
                        <TextBox Classes="event-type-input"
                                 Text="{Binding EventTypeHotkey, UpdateSourceTrigger=PropertyChanged}"
                                 TextInput="OnEventTypeHotkeyTextInput"
                                 TextChanged="OnEventTypeHotkeyTextChanged"
                                 KeyDown="OnEventTypeHotkeyEditorKeyDown"/>
                        <TextBlock Classes="input-placeholder"
                                   Text="Hotkey"
                                   IsVisible="{Binding EventTypeHotkey, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                      </Grid>
                      <Grid>
                        <TextBox Classes="event-type-input"
                                 Text="{Binding EventTypeColor}"/>
                        <TextBlock Classes="input-placeholder"
                                   Text="#RRGGBB"
                                   IsVisible="{Binding EventTypeColor, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                      </Grid>
                      <Grid>
                        <TextBox Classes="event-type-input"
                                 Text="{Binding EventTypeCategory}"/>
                        <TextBlock Classes="input-placeholder"
                                   Text="Категория"
                                   IsVisible="{Binding EventTypeCategory, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                      </Grid>
                      <Grid>
                        <TextBox Classes="event-type-input"
                                 Text="{Binding EventTypeIconKey}"/>
                        <TextBlock Classes="input-placeholder"
                                   Text="Icon key"
                                   IsVisible="{Binding EventTypeIconKey, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                      </Grid>
                    </StackPanel>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,*,*"
                          ColumnSpacing="10">
                      <Button Grid.Column="0"
                              Classes="action-button"
                              Command="{Binding SavePresetCommand}"
                              Content="Сохранить"/>
                      <Button Grid.Column="1"
                              Classes="action-button"
                              IsVisible="{Binding IsEditingPreset}"
                              Command="{Binding DeletePresetCommand}"
                              IsEnabled="{Binding CanDeleteEditedPreset}"
                              Content="Удалить"/>
                      <Button Grid.Column="2"
                              Classes="action-button"
                              Command="{Binding ClosePresetEditorCommand}"
                              Content="Закрыть"/>
                    </Grid>
                  </Grid>
                </Border>
              </Grid>
            </Border>

            <Border Grid.Row="0"
                    Grid.RowSpan="4"
                    Classes="editor-overlay"
                    IsVisible="{Binding IsTagEventEditorOpen}">
              <Grid HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Border Classes="editor-dialog"
                        x:Name="TagEventEditorDialog"
                        Focusable="True"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">
                  <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                      <TextBlock Text="{Binding TagEventEditorTitle}"
                                 FontSize="18"
                                 FontWeight="SemiBold"
                                 Foreground="#F7FAFF"/>
                      <Button x:Name="TagEventEditorCloseButton"
                              Grid.Column="1"
                              Classes="player-control-button"
                              Command="{Binding CloseTagEventEditorCommand}"
                              Content="X"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Spacing="10">
                      <ComboBox ItemsSource="{Binding TagPresets}"
                                SelectedItem="{Binding SelectedPreset, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="models:TagPreset">
                            <TextBlock Text="{Binding Name}"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Classes="event-type-input"
                                 Watermark="Начало"
                                 IsReadOnly="True"
                                 Text="{Binding TagStartFrame}"/>
                        <Button Grid.Column="1"
                                Classes="action-button"
                                Command="{Binding UseCurrentFrameForTagStartCommand}"
                                Content="Текущий"/>
                      </Grid>
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Classes="event-type-input"
                                 Watermark="Конец"
                                 IsReadOnly="True"
                                 Text="{Binding TagEndFrame}"/>
                        <Button Grid.Column="1"
                                Classes="action-button"
                                Command="{Binding UseCurrentFrameForTagEndCommand}"
                                Content="Текущий"/>
                      </Grid>
                      <ComboBox ItemsSource="{Binding EventTeamSides}"
                                SelectedItem="{Binding TagTeamSide, Mode=TwoWay}"/>
                      <Grid>
                        <TextBox Classes="event-type-input"
                                 Text="{Binding TagPlayer}"/>
                        <TextBlock Classes="input-placeholder"
                                   Text="Игрок"
                                   IsVisible="{Binding TagPlayer, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                      </Grid>
                      <Grid>
                        <TextBox Classes="event-type-input"
                                 Text="{Binding TagPeriod}"/>
                        <TextBlock Classes="input-placeholder"
                                   Text="Период"
                                   IsVisible="{Binding TagPeriod, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                      </Grid>
                      <Grid>
                        <TextBox Classes="event-type-input"
                                 Text="{Binding TagNotes}"/>
                        <TextBlock Classes="input-placeholder"
                                   Text="Заметки"
                                   IsVisible="{Binding TagNotes, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                      </Grid>
                    </StackPanel>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,*,*"
                          ColumnSpacing="10">
                      <Button Grid.Column="0"
                              Classes="action-button"
                              Command="{Binding AddTagCommand}"
                              Content="Сохранить"/>
                      <Button Grid.Column="1"
                              Classes="action-button"
                              IsVisible="{Binding IsEditingTagEvent}"
                              Command="{Binding DeleteSelectedTagCommand}"
                              IsEnabled="{Binding CanDeleteEditedTagEvent}"
                              Content="Удалить"/>
                      <Button Grid.Column="2"
                              Classes="action-button"
                              Command="{Binding CloseTagEventEditorCommand}"
                              Content="Закрыть"/>
                    </Grid>
                  </Grid>
                </Border>
              </Grid>
            </Border>
          </Grid>
        </ScrollViewer>
      </Border>

      <GridSplitter Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="3"
                    Width="6"
                    Background="#24324A"
                    ResizeDirection="Columns"
                    HorizontalAlignment="Stretch"/>

      <Border Grid.Row="0"
              Grid.RowSpan="3"
              Grid.Column="4"
              Classes="panel">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      ClipToBounds="True">
          <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="14" ClipToBounds="True">
            <StackPanel Spacing="4">
              <TextBlock Classes="section-title" Text="Плейлисты"/>
              <TextBlock Classes="section-subtitle" Text="Собирайте подборки из отмеченных событий, открывайте их в плеере и готовьте к экспорту."/>
            </StackPanel>

            <Border Grid.Row="1"
                    Classes="placeholder-card">
              <StackPanel Spacing="10">
                <TextBlock Text="Конструктор подборки"
                           FontSize="16"
                           FontWeight="SemiBold"/>
                <Grid>
                  <TextBox Classes="event-type-input"
                           Text="{Binding PlaylistName}"/>
                  <TextBlock Classes="input-placeholder"
                             Text="Название плейлиста"
                             IsVisible="{Binding PlaylistName, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                </Grid>
                <Grid>
                  <TextBox Classes="event-type-input"
                           Text="{Binding PlaylistDescription}"
                           AcceptsReturn="True"
                           TextWrapping="Wrap"
                           Height="70"/>
                  <TextBlock Classes="input-placeholder"
                             Text="Описание подборки"
                             VerticalAlignment="Top"
                             Margin="12,12,12,12"
                             IsVisible="{Binding PlaylistDescription, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Pre-roll"
                               Foreground="#AAB9CF"
                               FontSize="12"/>
                    <TextBox Classes="event-type-input"
                             Text="{Binding PreRollFrames}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Spacing="6">
                    <TextBlock Text="Post-roll"
                               Foreground="#AAB9CF"
                               FontSize="12"/>
                    <TextBox Classes="event-type-input"
                             Text="{Binding PostRollFrames}"/>
                  </StackPanel>
                </Grid>
                <TextBlock Text="{Binding SelectedPlaylistEventCount, StringFormat='Выбрано событий: {0}'}"
                           Foreground="#AAB9CF"/>
                <Button Classes="action-button"
                        Command="{Binding CreatePlaylistCommand}"
                        IsEnabled="{Binding CanCreatePlaylist}"
                        Content="Создать плейлист"/>
              </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Classes="placeholder-card">
              <StackPanel Spacing="10">
                <TextBlock Text="Сохраненные плейлисты"
                           FontSize="16"
                           FontWeight="SemiBold"/>
                <ListBox Classes="event-type-list"
                         ItemsSource="{Binding Playlists}"
                         SelectedItem="{Binding SelectedPlaylist, Mode=TwoWay}"
                         MaxHeight="220">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="items:PlaylistSummaryItemViewModel">
                      <Border Background="#162238"
                              BorderBrush="#2B3C59"
                              BorderThickness="1"
                              CornerRadius="8"
                              Padding="12,10">
                        <StackPanel Spacing="4">
                          <TextBlock Text="{Binding Name}"
                                     FontWeight="SemiBold"
                                     Foreground="#F7FAFF"/>
                          <TextBlock Text="{Binding Description}"
                                     Foreground="#C9D7EB"
                                     TextWrapping="Wrap"
                                     MaxLines="2"/>
                          <TextBlock Text="{Binding UpdatedAtText}"
                                     Foreground="#8FA3BF"
                                     FontSize="12"/>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                  <Button Grid.Column="0"
                          Classes="action-button"
                          Command="{Binding OpenSelectedPlaylistCommand}"
                          IsEnabled="{Binding CanOpenSelectedPlaylist}"
                          Content="Открыть"/>
                  <Button Grid.Column="1"
                          Classes="action-button"
                          Command="{Binding ExportCommand}"
                          IsEnabled="{Binding CanPlayActivePlaylist}"
                          Content="Экспорт"/>
                </Grid>
              </StackPanel>
            </Border>

            <Border Grid.Row="3"
                    Classes="placeholder-card">
              <Grid RowDefinitions="Auto,Auto,*,Auto"
                    RowSpacing="10">
                <TextBlock Text="Текущая подборка"
                           FontSize="16"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Row="1"
                           Text="{Binding ClipSummary}"
                           Foreground="#AAB9CF"/>

                <ListBox Grid.Row="2"
                         Classes="event-type-list"
                         ItemsSource="{Binding PlaylistItems}"
                         SelectedItem="{Binding SelectedPlaylistItem, Mode=TwoWay}"
                         IsVisible="{Binding HasPlaylistItems}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="items:PlaylistClipItemViewModel">
                      <Border Background="#162238"
                              BorderBrush="#2B3C59"
                              BorderThickness="1"
                              CornerRadius="8"
                              Padding="12,10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                          <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Label}"
                                       FontWeight="SemiBold"
                                       Foreground="#F7FAFF"/>
                            <TextBlock Text="{Binding FrameRangeText}"
                                       Foreground="#C9D7EB"/>
                            <TextBlock Text="{Binding Player}"
                                       Foreground="#8FA3BF"
                                       FontSize="12"/>
                          </StackPanel>
                          <Button Grid.Column="1"
                                  Classes="event-eye-button"
                                  Command="{Binding #RootWindow.DataContext.SeekToPlaylistItemCommand}"
                                  CommandParameter="{Binding}">
                            <TextBlock Text="▶"
                                       FontSize="12"/>
                          </Button>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="2"
                           Text="Пока нет открытого плейлиста."
                           Foreground="#AAB9CF"
                           IsVisible="{Binding HasNoPlaylistItems}"/>

                <Grid Grid.Row="3"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                  <Button Grid.Column="0"
                          Classes="action-button"
                          Command="{Binding PlayActivePlaylistCommand}"
                          IsEnabled="{Binding CanPlayActivePlaylist}"
                          Content="Воспроизвести"/>
                  <Button Grid.Column="1"
                          Classes="action-button"
                          Command="{Binding StopPlaylistPlaybackCommand}"
                          Content="Остановить"/>
                </Grid>
              </Grid>
            </Border>
          </Grid>
        </ScrollViewer>
      </Border>

      <GridSplitter Grid.Row="1"
                    Grid.Column="0"
                    Height="6"
                    Background="#24324A"
                    ResizeDirection="Rows"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>

      <Border Grid.Row="2" Grid.Column="0" Classes="panel">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      ClipToBounds="True">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14" ClipToBounds="True">
            <StackPanel Spacing="4">
              <TextBlock Classes="section-title" Text="Таймлайн"/>
              <TextBlock Classes="section-subtitle" Text="Нижняя левая зона для шкалы времени, маркеров и навигации"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Classes="placeholder-card"
                    Padding="12,8">
              <TextBlock Text="Будущий таймлайн будет размещён здесь"
                         Foreground="#AAB9CF"
                         TextWrapping="Wrap"/>
            </Border>

            <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="12">
              <Grid ColumnDefinitions="90,*" ColumnSpacing="12">
                <TextBlock Text="Время"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#D8E4F7"/>
                <Border Grid.Column="1"
                        Height="18"
                        CornerRadius="9"
                        Background="#162238"
                        BorderBrush="#2B3C59"
                        BorderThickness="1"/>
              </Grid>

              <Grid Grid.Row="1" ColumnDefinitions="120,*" ColumnSpacing="12">
                <StackPanel Spacing="10">
                  <Border Classes="placeholder-card" Padding="10">
                    <TextBlock Text="Слои событий" TextWrapping="Wrap"/>
                  </Border>
                  <Border Classes="placeholder-card" Padding="10">
                    <TextBlock Text="Фильтры" TextWrapping="Wrap"/>
                  </Border>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#0A101C"
                        BorderBrush="#2A3A55"
                        BorderThickness="1"
                        CornerRadius="8"
                        ClipToBounds="True">
                  <Grid Margin="14" ClipToBounds="True">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="*"/>
                      <RowDefinition Height="*"/>
                      <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="1" Margin="2" Background="#1A2640" CornerRadius="4"/>
                    <Border Grid.Row="0" Grid.Column="4" Margin="2" Background="#1A2640" CornerRadius="4"/>
                    <Border Grid.Row="1" Grid.Column="2" Margin="2" Background="#203867" CornerRadius="4"/>
                    <Border Grid.Row="1" Grid.Column="5" Margin="2" Background="#203867" CornerRadius="4"/>
                    <Border Grid.Row="2" Grid.Column="3" Margin="2" Background="#694D11" CornerRadius="4"/>
                  </Grid>
                </Border>
              </Grid>
            </Grid>
          </Grid>
        </ScrollViewer>
      </Border>
    </Grid>

    <Border Grid.RowSpan="2"
            Classes="startup-screen-overlay"
            IsVisible="{Binding IsStartupScreenVisible}">
      <Grid HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border Classes="startup-launcher"
                Width="896"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,*">
            <Border Classes="startup-header">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <StackPanel Spacing="4">
                  <TextBlock Classes="startup-title"
                             Text="Добро пожаловать в Hockey Video Analyzer"/>
                  <TextBlock Classes="startup-subtitle"
                             Text="Выберите действие для начала работы"/>
                </StackPanel>

                <Button x:Name="StartupCloseButton"
                        Grid.Column="1"
                        Classes="startup-close-button"
                        Command="{Binding CloseStartupScreenCommand}"
                        IsEnabled="{Binding CanCloseStartupScreen}"
                        Content="✕"/>
              </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="24"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="32">
              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="16">
                <Button x:Name="StartupPrimaryButton"
                        Classes="startup-action-card"
                        Command="{Binding OpenNewProjectDialogCommand}">
                  <Border Classes="startup-action-surface startup-action-surface-primary"
                          BorderBrush="#4C8DFF">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2B4666" Offset="0"/>
                        <GradientStop Color="#213650" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="33.6,17.6,17.6,17.6">
                      <Border Classes="startup-action-icon-shell"
                              Background="#30527D">
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#81C3FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="+"/>
                      </Border>

                      <StackPanel Margin="0,16,56,0"
                                  VerticalAlignment="Top"
                                  Spacing="8">
                        <TextBlock Classes="startup-action-title"
                                   Text="Новый проект"/>
                        <TextBlock Classes="startup-action-subtitle"
                                   Text="Создайте новый проект и импортируйте видео матча для анализа"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>

                <Button Grid.Column="1"
                        Classes="startup-action-card"
                        Command="{Binding OpenSelectedRecentProjectCommand}">
                  <Border Classes="startup-action-surface startup-action-surface-secondary"
                          BorderBrush="#B56BFF">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#43295A" Offset="0"/>
                        <GradientStop Color="#311E42" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="33.6,17.6,17.6,17.6">
                      <Border Classes="startup-action-icon-shell"
                              Background="#5A3680">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#E0B5FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="⤴"/>
                      </Border>

                      <StackPanel Margin="0,26,56,0"
                                  VerticalAlignment="Top"
                                  Spacing="8">
                        <TextBlock Classes="startup-action-title"
                                   Text="Открыть проект"/>
                        <TextBlock Classes="startup-action-subtitle"
                                   Text="Продолжите работу над существующим проектом"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>
              </Grid>

              <Grid Grid.Row="1"
                    RowDefinitions="Auto,Auto"
                    RowSpacing="16">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <TextBlock Classes="startup-section-title"
                             Text="НЕДАВНИЕ ПРОЕКТЫ"/>
                  <TextBlock Grid.Column="1"
                             Classes="startup-link"
                             Text="Показать все"/>
                </Grid>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding RecentProjects}"
                              IsVisible="{Binding HasRecentProjects}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal"
                                  Spacing="16"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="items:RecentProjectItemViewModel">
                      <Button Classes="startup-recent-card-button"
                              Command="{Binding #RootWindow.DataContext.OpenRecentProjectCommand}"
                              CommandParameter="{Binding}">
                        <Border Classes="recent-project-card">
                          <Grid RowDefinitions="Auto,*">
                            <Border Classes="recent-project-preview">
                              <Grid>
                                <Border Classes="recent-project-badge">
                                  <TextBlock Classes="recent-project-badge-text"
                                             Text="{Binding Matchup}"/>
                                </Border>
                              </Grid>
                            </Border>

                            <StackPanel Grid.Row="1"
                                        Margin="12"
                                        Spacing="4">
                              <TextBlock Classes="recent-project-title"
                                         Text="{Binding Name}"/>
                              <TextBlock Classes="recent-project-subtitle"
                                         MaxLines="2"
                                         Text="{Binding Summary}"/>
                              <TextBlock Classes="recent-project-meta"
                                         Margin="0,4,0,0"
                                         Text="{Binding UpdatedAtText}"/>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="1"
                        Classes="startup-empty-state"
                        IsVisible="{Binding HasNoRecentProjects}">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="recent-project-title"
                               Text="Пока нет проектов"/>
                    <TextBlock Classes="recent-project-subtitle"
                               Text="Создайте первый проект, и он появится здесь для быстрого запуска."/>
                  </StackPanel>
                </Border>
              </Grid>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border Grid.RowSpan="2"
            Classes="editor-overlay"
            IsVisible="{Binding IsNewProjectDialogOpen}">
      <Grid HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border Classes="new-project-dialog"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,Auto"
                Width="860"
                MaxWidth="860">
            <Border Background="#2F2F32"
                    BorderBrush="#4C566B"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Padding="24,22">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <StackPanel Spacing="6">
                  <TextBlock Classes="dialog-title"
                             Text="Создать новый проект"/>
                  <TextBlock Classes="dialog-subtitle"
                             Text="Введите информацию о новом проекте"/>
                </StackPanel>
                <Button x:Name="NewProjectCloseButton"
                        Grid.Column="1"
                        Classes="player-control-button"
                        Command="{Binding CloseNewProjectDialogCommand}"
                        Content="X"
                        VerticalAlignment="Top"/>
              </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#2F2F32"
                    CornerRadius="0,0,12,12"
                    Padding="24">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                    RowSpacing="22">
                <StackPanel Spacing="10">
                  <TextBlock Classes="form-label"
                             Text="Название проекта *"/>
                  <Border Classes="project-form-shell single-line">
                    <Grid>
                      <TextBox Classes="project-form-plain-input single-line"
                               Text="{Binding NewProjectName}"/>
                      <TextBlock Classes="project-input-placeholder"
                                 Text="Например: СКА vs ЦСКА 15.02.2024"
                                 Foreground="#8FA3BF"
                                 Opacity="1"
                                 IsVisible="{Binding NewProjectName, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                  </Border>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Spacing="10">
                  <TextBlock Classes="form-label"
                             Text="Описание (опционально)"/>
                  <Border Classes="project-form-shell">
                    <Grid>
                      <TextBox Classes="project-form-plain-input"
                               Text="{Binding NewProjectDescription}"
                               AcceptsReturn="True"
                               TextWrapping="Wrap"
                               Height="96"/>
                      <TextBlock Classes="project-input-placeholder multiline"
                                 Text="Добавьте заметки о матче..."
                                 Foreground="#8FA3BF"
                                 Opacity="1"
                                 IsVisible="{Binding NewProjectDescription, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                  </Border>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Spacing="10">
                  <TextBlock Classes="form-label"
                             Text="Видео *"/>
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="12">
                    <Border Classes="project-form-shell single-line">
                      <Grid>
                        <TextBox Classes="project-form-plain-input single-line"
                                 Text="{Binding NewProjectVideoPath}"/>
                        <TextBlock Classes="project-input-placeholder"
                                   Text="Путь к видеофайлу"
                                   Foreground="#8FA3BF"
                                   Opacity="1"
                                   IsVisible="{Binding NewProjectVideoPath, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                      </Grid>
                    </Border>
                    <Button Grid.Column="1"
                            Classes="dialog-secondary-button"
                            Click="OnBrowseNewProjectVideoClick"
                            Content="Выбрать"/>
                  </Grid>
                </StackPanel>

                <Grid Grid.Row="3"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="22">
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="14">
                    <StackPanel Spacing="10">
                      <TextBlock Classes="form-label"
                                 Text="Команда (хозяева)"/>
                      <Border Classes="project-form-shell single-line">
                        <Grid>
                          <TextBox Classes="project-form-plain-input single-line"
                                   Text="{Binding NewProjectHomeTeam}"/>
                          <TextBlock Classes="project-input-placeholder"
                                     Text="Название команды"
                                     Foreground="#8FA3BF"
                                     Opacity="1"
                                     IsVisible="{Binding NewProjectHomeTeam, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                        </Grid>
                      </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="10">
                      <TextBlock Classes="form-label"
                                 Text="Команда (гости)"/>
                      <Border Classes="project-form-shell single-line">
                        <Grid>
                          <TextBox Classes="project-form-plain-input single-line"
                                   Text="{Binding NewProjectAwayTeam}"/>
                          <TextBlock Classes="project-input-placeholder"
                                     Text="Название команды"
                                     Foreground="#8FA3BF"
                                     Opacity="1"
                                     IsVisible="{Binding NewProjectAwayTeam, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                        </Grid>
                      </Border>
                    </StackPanel>
                  </Grid>

                  <Grid Grid.Row="1"
                        ColumnDefinitions="*,*"
                        ColumnSpacing="14">
                    <Button Grid.Column="0"
                            Classes="dialog-secondary-button"
                            Command="{Binding CloseNewProjectDialogCommand}"
                            Content="Назад"/>
                    <Button Grid.Column="1"
                            Classes="dialog-primary-button"
                            Command="{Binding ContinueNewProjectCommand}"
                            Content="Далее: Импортировать видео"/>
                  </Grid>
                </Grid>
              </Grid>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
