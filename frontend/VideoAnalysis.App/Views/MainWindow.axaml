<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VideoAnalysis.App.ViewModels.Shell"
        xmlns:items="using:VideoAnalysis.App.ViewModels.Items"
        xmlns:converters="using:VideoAnalysis.App.Converters"
        xmlns:models="using:VideoAnalysis.Core.Models"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        x:Class="VideoAnalysis.App.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1600"
        Height="960"
        MinWidth="1180"
        MinHeight="760"
        Title="Video Analytics - Hockey MVP"
        Icon="/Assets/app-icon.ico"
        Background="#0B1220"
        Foreground="#E5EDF9"
        ClipToBounds="True">

  <Window.Resources>
    <converters:StringNullOrEmptyToBoolConverter x:Key="StringNullOrEmptyToBoolConverter"/>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Border.top-menu-bar">
      <Setter Property="Background" Value="#1D1D20"/>
      <Setter Property="Padding" Value="8,4"/>
    </Style>

    <Style Selector="Button.top-menu-item">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="14,6,14,10"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="14,6,14,10"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.top-menu-item /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.top-menu-item:pointerover">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:pointerover">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="Button.top-menu-item:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.top-menu-item:pressed">
      <Setter Property="Background" Value="#45454A"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:checked">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="Button.top-menu-item:pressed /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:checked /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Border.file-menu-popup">
      <Setter Property="Background" Value="#232327"/>
      <Setter Property="BorderBrush" Value="#3A3A3E"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="6"/>
      <Setter Property="BoxShadow" Value="0 8 24 0 #66000000"/>
    </Style>

    <Style Selector="Button.file-menu-item">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="MinWidth" Value="220"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.file-menu-item /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.file-menu-item:pointerover">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="Button.file-menu-item:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.player-button">
      <Setter Property="Background" Value="#24324A"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="Button.player-button:pointerover">
      <Setter Property="Background" Value="#304563"/>
    </Style>

    <Style Selector="Button.player-control-button, ToggleButton.player-control-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.player-control-button:pointerover, ToggleButton.player-control-button:pointerover">
      <Setter Property="Background" Value="#263246"/>
    </Style>

    <Style Selector="Button.player-control-button:pressed, ToggleButton.player-control-button:checked">
      <Setter Property="Background" Value="#304563"/>
    </Style>

    <Style Selector="Border.player-control-bar">
      <Setter Property="Background" Value="#1D1D20"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="10,6,10,14"/>
      <Setter Property="BorderBrush" Value="#2A3A55"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="Border.player-seek-surface">
      <Setter Property="Height" Value="28"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.player-seek-track">
      <Setter Property="Height" Value="4"/>
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Background" Value="#31435E"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.player-seek-progress">
      <Setter Property="Height" Value="4"/>
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Background" Value="#2F86FF"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Width" Value="0"/>
    </Style>

    <Style Selector="TextBox.player-input">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="CaretBrush" Value="#F7FAFF"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
    </Style>

    <Style Selector="TextBox.player-input:pointerover">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#3A567C"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.player-input:focus">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2F86FF"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.player-input /template/ Border">
      <Setter Property="Background" Value="#162238"/>
    </Style>

    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#111A2B"/>
      <Setter Property="BorderBrush" Value="#24324A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBlock.section-subtitle">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="Border.placeholder-card">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="TextBox.event-type-input">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="CaretBrush" Value="#F7FAFF"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#3A567C"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2F86FF"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ Border">
      <Setter Property="Background" Value="#162238"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ ContentControl#PART_Watermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus /template/ ContentControl#PART_Watermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover /template/ ContentControl#PART_Watermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ ContentControl#PART_FloatingWatermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus /template/ ContentControl#PART_FloatingWatermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover /template/ ContentControl#PART_FloatingWatermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ TextBlock#PlaceholderTextBlock">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus /template/ TextBlock#PlaceholderTextBlock">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover /template/ TextBlock#PlaceholderTextBlock">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBlock.input-placeholder">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Margin" Value="12,0,12,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>

    <Style Selector="TextBlock.project-input-placeholder">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Left"/>
      <Setter Property="IsHitTestVisible" Value="False"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBlock.project-input-placeholder.multiline">
      <Setter Property="Margin" Value="0"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style Selector="Button.action-button">
      <Setter Property="Background" Value="#203867"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="Button.action-button:pointerover">
      <Setter Property="Background" Value="#2A4A86"/>
    </Style>

    <Style Selector="Button.event-eye-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#9EB5D4"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="MinWidth" Value="24"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.event-eye-button:pointerover">
      <Setter Property="Background" Value="#24324A"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ListBox.event-type-list">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="ListBox.event-type-list ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Border.panel-tabs">
      <Setter Property="Background" Value="#171A20"/>
      <Setter Property="BorderBrush" Value="#2A3242"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="CornerRadius" Value="8,8,0,0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="ToggleButton.tab-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1,1,1,0"/>
      <Setter Property="Foreground" Value="#A9B5C9"/>
      <Setter Property="Padding" Value="14,12"/>
      <Setter Property="CornerRadius" Value="4,4,0,0"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="ToggleButton.tab-button:pointerover">
      <Setter Property="Background" Value="#1E2737"/>
      <Setter Property="Foreground" Value="#DCE6F5"/>
    </Style>

    <Style Selector="ToggleButton.tab-button:checked">
      <Setter Property="Background" Value="#243B62"/>
      <Setter Property="BorderBrush" Value="#E6ECF8"/>
      <Setter Property="Foreground" Value="#4FA0FF"/>
    </Style>

    <Style Selector="Border.editor-overlay">
      <Setter Property="Background" Value="#A0000000"/>
    </Style>

    <Style Selector="Border.editor-dialog">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="MaxWidth" Value="420"/>
      <Setter Property="Margin" Value="16"/>
    </Style>

    <Style Selector="Border.editor-overlay">
      <Setter Property="Background" Value="#A0000000"/>
    </Style>

    <Style Selector="Border.editor-dialog">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="MaxWidth" Value="420"/>
      <Setter Property="Margin" Value="16"/>
    </Style>

    <Style Selector="Border.new-project-dialog">
      <Setter Property="Background" Value="#2F2F32"/>
      <Setter Property="BorderBrush" Value="#4C566B"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Margin" Value="28"/>
      <Setter Property="MaxWidth" Value="900"/>
    </Style>

    <Style Selector="TextBlock.dialog-title">
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#F5F7FB"/>
    </Style>

    <Style Selector="TextBlock.dialog-subtitle">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="#AAB3C3"/>
    </Style>

    <Style Selector="TextBlock.form-label">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="#E2E8F3"/>
    </Style>

    <Style Selector="TextBox.project-form-input">
      <Setter Property="Background" Value="#1E1F22"/>
      <Setter Property="BorderBrush" Value="#365DA8"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#F5F7FB"/>
      <Setter Property="CaretBrush" Value="#F5F7FB"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
